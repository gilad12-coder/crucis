                          "name": "subViolationOutput",
                          "width": "fill_container",
                          "layout": "vertical",
                          "gap": 8,
                          "children": [
                            {
                              "type": "text",
                              "id": "CMtu7",
                              "name": "sub7h3",
                              "fill": "#2D1F14",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "Understanding violation output",
                              "fontFamily": "Space Grotesk",
                              "fontSize": 18,
                              "fontWeight": "600"
                            },
                            {
                              "type": "text",
                              "id": "TaPZj",
                              "name": "sub7p",
                              "fill": "#785E48",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "When generated tests violate constraints, Crucis shows which constraints failed:",
                              "lineHeight": 1.6,
                              "fontFamily": "Inter",
                              "fontSize": 14,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "frame",
                              "id": "IdcUS",
                              "name": "codeBlock11",
                              "width": "fill_container",
                              "fill": "#231A12",
                              "cornerRadius": 8,
                              "padding": [
                                8,
                                12
                              ],
                              "children": [
                                {
                                  "type": "text",
                                  "id": "pp3Sz",
                                  "name": "sub7codeText",
                                  "fill": "#e8e6e3",
                                  "textGrowth": "fixed-width",
                                  "width": "fill_container",
                                  "content": "Required constraint violations:\n  - max_cyclomatic_complexity: measured 18, limit 15\n  - max_lines_per_function: measured 95, limit 80",
                                  "lineHeight": 1.5,
                                  "fontFamily": "JetBrains Mono",
                                  "fontSize": 11,
                                  "fontWeight": "normal"
                                }
                              ]
                            },
                            {
                              "type": "text",
                              "id": "84O0d",
                              "name": "sub7note",
                              "fill": "#785E48",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "Required constraints are hard gates — the train suite is rejected and regenerated. Advisory constraints are soft gates — violations are reported but don't block approval.",
                              "lineHeight": 1.6,
                              "fontFamily": "Inter",
                              "fontSize": 14,
                              "fontWeight": "normal"
                            }
                          ]
                        },
                        {
                          "type": "frame",
                          "id": "HIldJ",
                          "name": "subAdjustProfiles",
                          "width": "fill_container",
                          "layout": "vertical",
                          "gap": 8,
                          "children": [
                            {
                              "type": "text",
                              "id": "Fcjkb",
                              "name": "sub8h3",
                              "fill": "#2D1F14",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "Adjusting constraint profiles",
                              "fontFamily": "Space Grotesk",
                              "fontSize": 18,
                              "fontWeight": "600"
                            },
                            {
                              "type": "text",
                              "id": "DymvD",
                              "name": "sub8p",
                              "fill": "#785E48",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "If constraints are too strict for your use case, create or modify constraints/profiles.yaml. Constraints use a flat list format — they are auto-classified as \"required\" (blocking) or \"advisory\" (non-blocking):",
                              "lineHeight": 1.6,
                              "fontFamily": "Inter",
                              "fontSize": 14,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "frame",
                              "id": "FhRqX",
                              "name": "codeBlock12",
                              "width": "fill_container",
                              "fill": "#231A12",
                              "cornerRadius": 8,
                              "padding": [
                                8,
                                12
                              ],
                              "children": [
                                {
                                  "type": "text",
                                  "id": "JhKZb",
                                  "name": "sub8codeText",
                                  "fill": "#e8e6e3",
                                  "textGrowth": "fixed-width",
                                  "width": "fill_container",
                                  "content": "profiles:\n  my_profile:\n    max_cyclomatic_complexity: 20\n    max_lines_per_function: 100\n    require_docstrings: true",
                                  "lineHeight": 1.5,
                                  "fontFamily": "JetBrains Mono",
                                  "fontSize": 11,
                                  "fontWeight": "normal"
                                }
                              ]
                            },
