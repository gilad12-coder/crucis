                    },
                    {
                      "type": "text",
                      "id": "S1bao",
                      "name": "inheritNote",
                      "fill": "#785E48",
                      "content": "Inheritance: Task-level fields override top-level fields when set. context_files and existing_tests are merged (both levels are included).",
                      "lineHeight": 1.6,
                      "fontFamily": "Inter",
                      "fontSize": 14,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "jhKcQ",
                      "name": "h2_eval",
                      "fill": "#2D1F14",
                      "content": "Eval schema",
                      "fontFamily": "Space Grotesk",
                      "fontSize": 23,
                      "fontWeight": "600"
                    },
                    {
                      "type": "text",
                      "id": "RKBtS",
                      "name": "evalExplain",
                      "fill": "#785E48",
                      "content": "Both train_evals and holdout_evals use the same format:",
                      "lineHeight": 1.6,
                      "fontFamily": "Inter",
                      "fontSize": 14,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "frame",
                      "id": "deeLq",
                      "name": "code_eval",
                      "width": "fill_container",
                      "fill": "#231A12",
                      "cornerRadius": 10,
                      "padding": [
                        16,
                        20
                      ],
                      "children": [
                        {
                          "type": "text",
                          "id": "Qgy2V",
                          "fill": "#e8e6e3",
                          "content": "train_evals:\n  - input: \"(1, 2)\"\n    output: \"3\"",
                          "lineHeight": 1.5,
                          "fontFamily": "JetBrains Mono",
                          "fontSize": 12.5,
                          "fontWeight": "normal"
                        }
                      ]
                    },
                    {
                      "type": "text",
                      "id": "IweOA",
                      "name": "evalInputDesc",
                      "fill": "#785E48",
                      "content": "• input — Python expression representing call arguments as a tuple (e.g. \"(1, 2)\" means func(1, 2))\n• output — Python expression representing the expected return value",
                      "lineHeight": 1.6,
                      "fontFamily": "Inter",
                      "fontSize": 14,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "W6wSu",
                      "name": "autoHoldout",
                      "fill": "#785E48",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "Auto-holdout: If you only provide examples (or train_evals) without a holdout_evals key, Crucis automatically splits the last ~20% as holdout evals. To provide explicit holdout evals, add a holdout: key. To opt out of auto-holdout, set holdout: [].",
                      "lineHeight": 1.6,
                      "fontFamily": "Inter",
                      "fontSize": 14,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "ALvgd",
                      "name": "holdoutReqs",
                      "fill": "#785E48",
                      "content": "Holdout evals have stricter requirements:\n• Both input and output are required\n• Values must be strings\n• Expressions must parse as valid Python eval expressions\n• The raw key is not allowed",
                      "lineHeight": 1.6,
                      "fontFamily": "Inter",
                      "fontSize": 14,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "3OXYJ",
                      "name": "h2_verif",
                      "fill": "#2D1F14",
                      "content": "Verification granularity",
                      "fontFamily": "Space Grotesk",
                      "fontSize": 23,
                      "fontWeight": "600"
                    },
                    {
                      "type": "text",
                      "id": "6dQ9E",
                      "name": "verifDesc",
                      "fill": "#785E48",
                      "content": "Controls how Crucis evaluates implementation correctness:\n• task (default) — each task’s tests run independently; all must pass\n• objective — all tests run as a single batch",
