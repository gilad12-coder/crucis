                          "name": "q1",
                          "width": "fill_container",
                          "layout": "vertical",
                          "gap": 12,
                          "children": [
                            {
                              "type": "text",
                              "id": "7zu9g",
                              "name": "q1h",
                              "fill": "#2D1F14",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "Which Python versions are supported?",
                              "fontFamily": "Space Grotesk",
                              "fontSize": 18,
                              "fontWeight": "600"
                            },
                            {
                              "type": "text",
                              "id": "3DvAi",
                              "name": "q1a",
                              "fill": "#785E48",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "Python 3.10+ is supported. Python 3.12+ is recommended for the best experience. Versions below 3.10 are rejected at runtime. Run crucis doctor to check your version.",
                              "lineHeight": 1.6,
                              "fontFamily": "Inter",
                              "fontSize": 14,
                              "fontWeight": "normal"
                            }
                          ]
                        },
                        {
                          "type": "frame",
                          "id": "ZPRTp",
                          "name": "q4",
                          "width": "fill_container",
                          "layout": "vertical",
                          "gap": 12,
                          "children": [
                            {
                              "type": "text",
                              "id": "jUdiI",
                              "name": "q4h",
                              "fill": "#2D1F14",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "Do I need Docker?",
                              "fontFamily": "Space Grotesk",
                              "fontSize": 18,
                              "fontWeight": "600"
                            },
                            {
                              "type": "text",
                              "id": "GPkqW",
                              "name": "q4a",
                              "fill": "#785E48",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "No. Docker is optional. When Docker is unavailable, Crucis runs pytest directly on the host. Use --no-sandbox to explicitly skip Docker. See Troubleshooting.",
                              "lineHeight": 1.6,
                              "fontFamily": "Inter",
                              "fontSize": 14,
                              "fontWeight": "normal"
                            }
                          ]
                        },
                        {
                          "type": "frame",
                          "id": "sz0U9",
                          "name": "q6",
                          "width": "fill_container",
                          "layout": "vertical",
                          "gap": 12,
                          "children": [
                            {
                              "type": "text",
                              "id": "rD9nG",
                              "name": "q6h",
                              "fill": "#2D1F14",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "How do I use Crucis with an existing codebase?",
                              "fontFamily": "Space Grotesk",
                              "fontSize": 18,
                              "fontWeight": "600"
                            },
                            {
                              "type": "text",
                              "id": "rfRvs",
                              "name": "q6a",
                              "fill": "#785E48",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "Use crucis init --existing-codebase and set target_files, context_files, and existing_tests in your objective. See Existing Codebase Quickstart.",
                              "lineHeight": 1.6,
                              "fontFamily": "Inter",
                              "fontSize": 14,
                              "fontWeight": "normal"
                            }
                          ]
                        },
                        {
                          "type": "frame",
                          "id": "rACkZ",
                          "name": "qCost",
                          "width": "fill_container",
                          "layout": "vertical",
                          "gap": 12,
                          "children": [
                            {
                              "type": "text",
                              "id": "X76SG",
                              "name": "mCostQ",
                              "fill": "#2D1F14",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "How much does it cost?",
                              "fontFamily": "Space Grotesk",
                              "fontSize": 16,
                              "fontWeight": "600"
                            },
                            {
                              "type": "text",
                              "id": "UlNTz",
                              "name": "mCostA",
                              "fill": "#785E48",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "Crucis itself is free and open source. The only cost is API calls to your chosen LLM provider. A typical run uses 2-5 API calls per task for test generation and 1-3 for implementation.",
                              "lineHeight": 1.6,
                              "fontFamily": "Inter",
                              "fontSize": 14,
                              "fontWeight": "normal"
                            }
                          ]
                        }
                      ]
                    },
                    {
                      "type": "frame",
