                          "name": "holdoutPara",
                          "fill": "#785E48",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "You don't need to manually split examples into train and holdout sets. Just list your examples under examples: and Crucis automatically holds out the last ~20% for verification. If you need manual control, you can still use an explicit holdout: field. Use holdout: [] to opt out of holdout verification entirely.",
                          "lineHeight": 1.6,
                          "fontFamily": "Inter",
                          "fontSize": 14,
                          "fontWeight": "normal"
                        }
