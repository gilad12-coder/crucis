                          "fontFamily": "Space Grotesk",
                          "fontSize": 18,
                          "fontWeight": "600"
                        },
                        {
                          "type": "frame",
                          "id": "QiUhA",
                          "name": "codeBlock",
                          "width": "fill_container",
                          "fill": "#231A12",
