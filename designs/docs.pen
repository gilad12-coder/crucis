                              "fontSize": 18,
                              "fontWeight": "600"
                            },
                            {
                              "type": "frame",
                              "id": "XgdPG",
                              "name": "codeBlock5",
                              "width": "fill_container",
                              "fill": "#231A12",
                              "cornerRadius": 8,
                              "padding": [
                                8,
                                12
                              ],
                              "children": [
                                {
                                  "type": "text",
                                  "id": "ppzYJ",
                                  "name": "sub3codeText",
                                  "fill": "#e8e6e3",
                                  "textGrowth": "fixed-width",
                                  "width": "fill_container",
                                  "content": "Error: claude binary not found on PATH",
                                  "lineHeight": 1.5,
                                  "fontFamily": "JetBrains Mono",
                                  "fontSize": 11,
                                  "fontWeight": "normal"
                                }
                              ]
                            },
                            {
                              "type": "text",
                              "id": "1K0as",
                              "name": "sub3p",
                              "fill": "#785E48",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "Crucis runs agents as CLI subprocesses. Ensure the agent binary is installed and on your PATH:",
                              "lineHeight": 1.6,
                              "fontFamily": "Inter",
                              "fontSize": 14,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "frame",
                              "id": "E7UMG",
                              "name": "codeBlock6",
                              "width": "fill_container",
                              "fill": "#231A12",
                              "cornerRadius": 8,
                              "padding": [
                                8,
                                12
                              ],
                              "children": [
                                {
                                  "type": "text",
                                  "id": "XNuBL",
                                  "name": "sub3fixText",
                                  "fill": "#e8e6e3",
                                  "textGrowth": "fixed-width",
                                  "width": "fill_container",
                                  "content": "which claude\nwhich codex",
                                  "lineHeight": 1.5,
                                  "fontFamily": "JetBrains Mono",
                                  "fontSize": 11,
                                  "fontWeight": "normal"
                                }
                              ]
                            },
                            {
                              "type": "text",
                              "id": "X3e8E",
                              "name": "sub3note",
                              "fill": "#785E48",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "If the binary is missing, install the relevant CLI tool. The agent returns exit_code=-1 when the binary is not found, and Crucis retries with the next iteration.\n\nRun diagnostics to verify binaries and environment quickly:",
                              "lineHeight": 1.6,
                              "fontFamily": "Inter",
                              "fontSize": 14,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "frame",
                              "id": "Eii1T",
                              "name": "codeBlock6b",
                              "width": "fill_container",
                              "fill": "#231A12",
                              "cornerRadius": 8,
                              "padding": [
                                8,
                                12
                              ],
                              "children": [
                                {
                                  "type": "text",
                                  "id": "ySGa4",
                                  "name": "sub3doctorText",
                                  "fill": "#e8e6e3",
                                  "textGrowth": "fixed-width",
                                  "width": "fill_container",
                                  "content": "crucis doctor --workspace . --json",
                                  "lineHeight": 1.5,
                                  "fontFamily": "JetBrains Mono",
                                  "fontSize": 11,
                                  "fontWeight": "normal"
                                }
                              ]
                            }
                          ]
                        },
                        {
                          "type": "frame",
                          "id": "vsatK",
                          "name": "subAgentTimeout",
                          "width": "fill_container",
                          "layout": "vertical",
                          "gap": 8,
                          "children": [
                            {
                              "type": "text",
                              "id": "2PNuM",
                              "name": "sub4h3",
                              "fill": "#2D1F14",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "Agent timeout",
                              "fontFamily": "Space Grotesk",
                              "fontSize": 18,
                              "fontWeight": "600"
                            },
                            {
                              "type": "frame",
                              "id": "PDL52",
                              "name": "codeBlock7",
                              "width": "fill_container",
                              "fill": "#231A12",
                              "cornerRadius": 8,
                              "padding": [
                                8,
                                12
                              ],
                              "children": [
                                {
                                  "type": "text",
                                  "id": "I6hMz",
                                  "name": "sub4codeText",
                                  "fill": "#e8e6e3",
                                  "textGrowth": "fixed-width",
                                  "width": "fill_container",
                                  "content": "Error: Agent timed out after 300s",
                                  "lineHeight": 1.5,
                                  "fontFamily": "JetBrains Mono",
                                  "fontSize": 11,
                                  "fontWeight": "normal"
                                }
                              ]
                            },
                            {
                              "type": "text",
                              "id": "52LUi",
                              "name": "sub4p",
                              "fill": "#785E48",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "The default agent timeout is 300 seconds. If your objective is complex or the model is slow, the agent may time out. Crucis treats this as a failed attempt and retries.\n\nTo increase the timeout, pass --timeout to the run command:",
                              "lineHeight": 1.6,
                              "fontFamily": "Inter",
                              "fontSize": 14,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "frame",
                              "id": "018gE",
                              "name": "codeBlock8",
                              "width": "fill_container",
                              "fill": "#231A12",
                              "cornerRadius": 8,
                              "padding": [
                                8,
                                12
                              ],
                              "children": [
                                {
                                  "type": "text",
                                  "id": "yVTTO",
                                  "name": "sub4fixText",
                                  "fill": "#e8e6e3",
                                  "textGrowth": "fixed-width",
                                  "width": "fill_container",
                                  "content": "crucis run --timeout 600   # 10 minutes",
                                  "lineHeight": 1.5,
                                  "fontFamily": "JetBrains Mono",
                                  "fontSize": 11,
                                  "fontWeight": "normal"
                                }
                              ]
                            },
                            {
                              "type": "text",
                              "id": "bj7lJ",
                              "name": "sub4tips",
                              "fill": "#785E48",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "Other options to reduce timeouts:\n• Simplify the objective (fewer train evals, simpler constraints)\n• Use a faster model via config\n• Reduce max_budget_usd to limit agent thinking time",
                              "lineHeight": 1.6,
                              "fontFamily": "Inter",
                              "fontSize": 14,
                              "fontWeight": "normal"
                            }
                          ]
                        }
                      ]
                    },
                    {
                      "type": "frame",
                      "id": "E2gtW",
                      "name": "sectionDocker",
                      "width": "fill_container",
