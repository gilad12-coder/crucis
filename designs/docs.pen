                    },
                    {
                      "type": "frame",
                      "id": "aeHiv",
                      "name": "sectionFitPhase",
                      "width": "fill_container",
                      "layout": "vertical",
                      "gap": 12,
                      "children": [
                        {
                          "type": "text",
                          "id": "gQW6m",
                          "name": "h2_fit",
                          "fill": "#2D1F14",
                          "content": "Fit Phase",
                          "fontFamily": "Space Grotesk",
                          "fontSize": 23,
                          "fontWeight": "600"
                        },
                        {
                          "type": "text",
                          "id": "rmXXI",
                          "name": "fitPara",
                          "fill": "#785E48",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "The Fit phase generates and hardens test suites. Each task is processed sequentially. A generation agent builds a pytest file from the objective, then Crucis validates it with syntax and constraint checks. An adversarial reviewer searches for attack vectors and generalization gaps. A cheating probe then builds a deliberately deceptive implementation and runs it against the suite. If the probe passes, adversarial findings feed back into test generation and the cycle restarts.",
                          "lineHeight": 1.6,
                          "fontFamily": "Inter",
                          "fontSize": 14,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "frame",
                          "id": "YtRJo",
                          "name": "codeBlock",
                          "width": "fill_container",
                          "fill": "#231A12",
                          "cornerRadius": 10,
                          "layout": "vertical",
                          "padding": [
                            16,
                            20
                          ],
                          "children": [
                            {
                              "type": "text",
                              "id": "RET93",
                              "name": "fitCodeT",
                              "fill": "#e8e6e3",
                              "content": "crucis run-fit          # Generate + harden tests\ncrucis summary          # Check Fit phase status\ncrucis summary task_x   # Detailed view with test source",
                              "lineHeight": 1.6,
                              "fontFamily": "JetBrains Mono",
                              "fontSize": 12.5,
                              "fontWeight": "normal"
                            }
                          ]
                        }
                      ]
                    },
                    {
                      "type": "frame",
                      "id": "QLfvI",
                      "name": "sectionEvalPhase",
                      "width": "fill_container",
                      "layout": "vertical",
                      "gap": 12,
                      "children": [
                        {
                          "type": "text",
                          "id": "mkPxi",
                          "name": "h2_eval",
                          "fill": "#2D1F14",
                          "content": "Evaluation Phase",
                          "fontFamily": "Space Grotesk",
                          "fontSize": 23,
                          "fontWeight": "600"
                        },
                        {
                          "type": "text",
                          "id": "cQa8N",
                          "name": "evalPara",
                          "fill": "#785E48",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "The Evaluate phase takes the checkpoint and generates an implementation. It writes test files to disk, builds a curriculum from objective metadata and per-task details, and dispatches an implementation agent. The result is verified against both the generated train suites and hidden holdout evaluations. Holdout evals are automatically split from the last ~20% of the examples list — no manual setup needed.",
                          "lineHeight": 1.6,
                          "fontFamily": "Inter",
                          "fontSize": 14,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "frame",
                          "id": "MSOrA",
                          "name": "codeBlock",
                          "width": "fill_container",
                          "fill": "#231A12",
                          "cornerRadius": 10,
                          "layout": "vertical",
                          "padding": [
                            16,
                            20
                          ],
                          "children": [
                            {
                              "type": "text",
                              "id": "CLV3z",
                              "name": "evalCodeT",
                              "fill": "#e8e6e3",
                              "content": "crucis run-evaluate     # Implement + verify\ncrucis run              # Full pipeline (fit + evaluate)",
                              "lineHeight": 1.6,
                              "fontFamily": "JetBrains Mono",
                              "fontSize": 12.5,
                              "fontWeight": "normal"
                            }
                          ]
                        }
                      ]
                    },
                    {
                      "type": "frame",
                      "id": "Ne2JA",
                      "name": "sectionAdversarial",
                      "width": "fill_container",
                      "layout": "vertical",
                      "gap": 12,
                      "children": [
                        {
                          "type": "text",
                          "id": "VHuSP",
                          "name": "h2_adv",
                          "fill": "#2D1F14",
                          "content": "Adversarial Testing",
                          "fontFamily": "Space Grotesk",
                          "fontSize": 23,
                          "fontWeight": "600"
                        },
                        {
                          "type": "text",
                          "id": "fQFUf",
                          "name": "advPara",
                          "fill": "#785E48",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "The adversarial system has three components:\n\n1. Review — the critic agent analyzes test quality, identifying attack strategies and gaps\n2. Probe — a cheating implementation is generated and tested, measuring actual test robustness\n3. Feedback loop — adversarial findings feed back into test generation, producing harder tests\n\nThis creates an arms race: better attacks produce better tests, which produce better implementations.",
                          "lineHeight": 1.6,
                          "fontFamily": "Inter",
                          "fontSize": 14,
                          "fontWeight": "normal"
                        }
                      ]
                    },
                    {
                      "type": "frame",
                      "id": "g4cls",
                      "name": "sectionErrorRecovery",
                      "width": "fill_container",
                      "layout": "vertical",
                      "gap": 12,
                      "children": [
                        {
                          "type": "text",
                          "id": "N2GZ7",
                          "name": "h2_err",
                          "fill": "#2D1F14",
                          "content": "Error Recovery",
                          "fontFamily": "Space Grotesk",
                          "fontSize": 23,
                          "fontWeight": "600"
                        },
                        {
                          "type": "frame",
                          "id": "x3kiQ",
                          "name": "errBulletList",
                          "width": "fill_container",
                          "layout": "vertical",
                          "gap": 6,
                          "padding": [
                            0,
                            0,
                            0,
                            16
                          ],
                          "children": [
                            {
                              "type": "text",
                              "id": "aCeuX",
                              "name": "eb1",
                              "fill": "#785E48",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "•  Agent timeout — treated as a failed attempt, retried with the next iteration (default: 300s)",
                              "lineHeight": 1.6,
                              "fontFamily": "Inter",
                              "fontSize": 14,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "text",
                              "id": "1LlVv",
                              "name": "eb2",
                              "fill": "#785E48",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "•  Missing agent binary — returns exit_code=-1, retried",
                              "lineHeight": 1.6,
                              "fontFamily": "Inter",
                              "fontSize": 14,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "text",
                              "id": "VQqvF",
                              "name": "eb3",
                              "fill": "#785E48",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "•  Malformed adversarial JSON — repaired via json_repair library",
                              "lineHeight": 1.6,
                              "fontFamily": "Inter",
                              "fontSize": 14,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "text",
                              "id": "FhvrM",
                              "name": "eb4",
                              "fill": "#785E48",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "•  Docker unavailable — falls back to host pytest",
                              "lineHeight": 1.6,
                              "fontFamily": "Inter",
                              "fontSize": 14,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "text",
                              "id": "GhsxB",
                              "name": "eb5",
                              "fill": "#785E48",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "•  Constraint violations — violation details fed back to generation prompt for correction",
                              "lineHeight": 1.6,
