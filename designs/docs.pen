                      "name": "intro1",
                      "fill": "#785E48",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "Build a verified function from scratch using Crucis, an autonomy scaffold for code-generating agents that provides structured automated feedback.",
                      "lineHeight": 1.6,
                      "fontFamily": "Inter",
                      "fontSize": 14,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "frame",
                      "id": "Kc18k",
                      "name": "section1",
                      "width": "fill_container",
                      "layout": "vertical",
                      "gap": 12,
                      "children": [
                        {
                          "type": "text",
                          "id": "FlTDV",
                          "name": "sec1h",
                          "fill": "#2D1F14",
                          "content": "1. Create a workspace",
                          "fontFamily": "Space Grotesk",
                          "fontSize": 23,
                          "fontWeight": "600"
                        },
                        {
                          "type": "frame",
                          "id": "TTWSY",
                          "name": "codeBlock",
                          "width": "fill_container",
                          "fill": "#231A12",
                          "cornerRadius": 10,
                          "padding": [
                            16,
                            20
                          ],
                          "children": [
                            {
                              "type": "text",
                              "id": "nhtv3",
                              "name": "sec1ct",
                              "fill": "#e8e6e3",
                              "content": "mkdir my-project && cd my-project\ncrucis init --name add --no-agent",
                              "lineHeight": 1.5,
                              "fontFamily": "JetBrains Mono",
                              "fontSize": 12.5,
                              "fontWeight": "normal"
                            }
                          ]
                        }
                      ]
                    },
                    {
                      "type": "frame",
                      "id": "itJyE",
                      "name": "section2",
