                              "content": "How It Works",
                              "fontFamily": "Space Grotesk",
                              "fontSize": 18,
                              "fontWeight": "600"
                            }
                          ]
                        },
                        {
                          "type": "frame",
                          "id": "3RoYv",
                          "name": "q3",
                          "width": "fill_container",
                          "layout": "vertical",
                          "gap": 12,
                          "children": [
                            {
                              "type": "text",
                              "id": "SEZT0",
                              "name": "q3h",
                              "fill": "#2D1F14",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "What happens if fit is interrupted?",
                              "fontFamily": "Space Grotesk",
                              "fontSize": 18,
                              "fontWeight": "600"
                            },
                            {
                              "type": "text",
                              "id": "Z1dm7",
                              "name": "q3a",
                              "fill": "#785E48",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "Crucis saves the checkpoint after each task completes. Re-run the same command and it resumes from the last completed task. No work is lost.",
                              "lineHeight": 1.6,
                              "fontFamily": "Inter",
                              "fontSize": 14,
                              "fontWeight": "normal"
                            }
                          ]
                        },
                        {
                          "type": "frame",
                          "id": "FlcOo",
                          "name": "q5",
                          "width": "fill_container",
                          "layout": "vertical",
                          "gap": 12,
                          "children": [
                            {
                              "type": "text",
                              "id": "nRJWy",
                              "name": "q5h",
                              "fill": "#2D1F14",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "What are holdout evals?",
                              "fontFamily": "Space Grotesk",
                              "fontSize": 18,
                              "fontWeight": "600"
                            },
                            {
                              "type": "text",
                              "id": "0nHRp",
                              "name": "q5a",
                              "fill": "#785E48",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "Hidden input/output pairs that are never shown to any agent. After the implementation agent writes code, Crucis runs these pairs as a final safety net to verify the implementation generalizes beyond the training examples.\n\nYou don't need to write them manually. Just list all your examples under examples: and Crucis automatically reserves the last ~20% as holdout evals (auto-holdout). You can still provide an explicit holdout: section if you prefer full control. See Objective Format Reference.",
                              "lineHeight": 1.6,
                              "fontFamily": "Inter",
                              "fontSize": 14,
                              "fontWeight": "normal"
                            }
                          ]
                        },
                        {
                          "type": "frame",
                          "id": "2O8iV",
                          "name": "q7",
                          "width": "fill_container",
                          "layout": "vertical",
                          "gap": 12,
                          "children": [
                            {
                              "type": "text",
                              "id": "RWuUI",
                              "name": "q7h",
                              "fill": "#2D1F14",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "What does the optimizer do?",
                              "fontFamily": "Space Grotesk",
                              "fontSize": 18,
                              "fontWeight": "600"
                            },
                            {
                              "type": "text",
                              "id": "7yGzC",
                              "name": "q7a",
                              "fill": "#785E48",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "The background optimizer (GEPA) learns better prompt strategies over time by analyzing generation outcomes across runs. It's experimental and disabled by default. To enable it, set optimizer.enabled: true in .crucis/settings.yaml. See Background Optimizer.",
                              "lineHeight": 1.6,
                              "fontFamily": "Inter",
                              "fontSize": 14,
                              "fontWeight": "normal"
                            }
                          ]
                        }
                      ]
                    },
                    {
                      "type": "frame",
                      "id": "eYS0f",
                      "name": "sectionConfigCustom",
                      "width": "fill_container",
                      "layout": "vertical",
                      "gap": 16,
                      "children": [
                        {
                          "type": "frame",
                          "id": "dVBMp",
                          "name": "h2Wrapper",
                          "width": "fill_container",
                          "gap": 8,
                          "alignItems": "center",
                          "children": [
                            {
                              "type": "icon_font",
                              "id": "pw4GT",
                              "name": "mS3icon",
                              "width": 20,
                              "height": 20,
                              "iconFontName": "settings",
                              "iconFontFamily": "lucide",
                              "fill": "#785E48"
                            },
                            {
                              "type": "text",
                              "id": "xJjgY",
                              "name": "mS3h2",
                              "fill": "#2D1F14",
                              "content": "Configuration & Customization",
                              "fontFamily": "Space Grotesk",
                              "fontSize": 18,
                              "fontWeight": "600"
                            }
                          ]
                        },
                        {
                          "type": "frame",
                          "id": "9gzPh",
                          "name": "q2",
                          "width": "fill_container",
                          "layout": "vertical",
                          "gap": 12,
                          "children": [
                            {
                              "type": "text",
                              "id": "YVpey",
                              "name": "q2h",
                              "fill": "#2D1F14",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "How do I switch between Claude and Codex?",
                              "fontFamily": "Space Grotesk",
                              "fontSize": 18,
                              "fontWeight": "600"
                            },
                            {
                              "type": "text",
                              "id": "RxYCv",
                              "name": "q2a",
                              "fill": "#785E48",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "Edit .crucis/settings.yaml:",
                              "lineHeight": 1.6,
                              "fontFamily": "Inter",
                              "fontSize": 14,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "frame",
                              "id": "toryL",
                              "name": "codeBlock",
                              "width": "fill_container",
                              "fill": "#231A12",
                              "cornerRadius": 8,
                              "padding": [
                                8,
                                12
                              ],
                              "children": [
                                {
                                  "type": "text",
                                  "id": "IZFbo",
                                  "name": "q2codeText",
                                  "fill": "#e8e6e3",
                                  "textGrowth": "fixed-width",
                                  "width": "fill_container",
                                  "content": "agents:\n  generation_agent: codex   # or &quot;claude&quot;\n  generation_model: null     # null = agent default",
                                  "lineHeight": 1.5,
                                  "fontFamily": "JetBrains Mono",
                                  "fontSize": 11,
                                  "fontWeight": "normal"
                                }
                              ]
                            },
                            {
                              "type": "text",
                              "id": "susrA",
                              "name": "q2b",
                              "fill": "#785E48",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "Or set environment variables: GENERATION_AGENT=codex. See Configuration for all agent settings.",
                              "lineHeight": 1.6,
                              "fontFamily": "Inter",
                              "fontSize": 14,
                              "fontWeight": "normal"
                            }
                          ]
                        },
                        {
                          "type": "frame",
                          "id": "jWLKa",
                          "name": "q8",
                          "width": "fill_container",
                          "layout": "vertical",
                          "gap": 12,
                          "children": [
                            {
                              "type": "text",
                              "id": "n40C1",
                              "name": "q8h",
                              "fill": "#2D1F14",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "Can I use Crucis from Claude Code / OpenCode / Codex?",
                              "fontFamily": "Space Grotesk",
                              "fontSize": 18,
                              "fontWeight": "600"
                            },
                            {
                              "type": "text",
                              "id": "fQico",
                              "name": "q8a",
                              "fill": "#785E48",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "Yes. Crucis ships an MCP server (crucis-mcp) that exposes every CLI command as a tool your agent can call. Add it to your MCP config and authorize the workspace:",
                              "lineHeight": 1.6,
                              "fontFamily": "Inter",
                              "fontSize": 14,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "frame",
                              "id": "Y4C3Y",
                              "name": "codeBlock",
                              "width": "fill_container",
                              "fill": "#231A12",
                              "cornerRadius": 8,
                              "padding": [
                                8,
                                12
                              ],
                              "children": [
                                {
                                  "type": "text",
                                  "id": "sclpy",
                                  "name": "q8codeText",
                                  "fill": "#e8e6e3",
                                  "textGrowth": "fixed-width",
                                  "width": "fill_container",
                                  "content": "mkdir -p .crucis && touch .crucis/mcp_enabled",
                                  "lineHeight": 1.5,
                                  "fontFamily": "JetBrains Mono",
                                  "fontSize": 11,
                                  "fontWeight": "normal"
                                }
                              ]
                            },
                            {
                              "type": "text",
                              "id": "Ila3i",
                              "name": "q8b",
                              "fill": "#785E48",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "See MCP Server for setup, tool reference, and the step-by-step agent workflow.",
                              "lineHeight": 1.6,
                              "fontFamily": "Inter",
                              "fontSize": 14,
                              "fontWeight": "normal"
                            }
                          ]
                        },
                        {
                          "type": "frame",
                          "id": "gAJRk",
                          "name": "q9",
                          "width": "fill_container",
                          "layout": "vertical",
                          "gap": 12,
                          "children": [
                            {
                              "type": "text",
                              "id": "1MHSi",
                              "name": "q9h",
                              "fill": "#2D1F14",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "How do I reset a failed checkpoint?",
                              "fontFamily": "Space Grotesk",
                              "fontSize": 18,
                              "fontWeight": "600"
                            },
                            {
                              "type": "frame",
                              "id": "2x2kt",
                              "name": "codeBlock",
                              "width": "fill_container",
                              "fill": "#231A12",
                              "cornerRadius": 8,
                              "padding": [
                                8,
                                12
                              ],
                              "children": [
                                {
                                  "type": "text",
                                  "id": "4iIrU",
                                  "name": "q9codeText",
                                  "fill": "#e8e6e3",
                                  "textGrowth": "fixed-width",
                                  "width": "fill_container",
                                  "content": "# Reset everything (prompts for confirmation)\ncrucis run --reset\n\n# Skip the confirmation prompt\ncrucis run --reset -y\n\n# Reset only specific tasks\ncrucis run --reset-task my_task",
                                  "lineHeight": 1.5,
                                  "fontFamily": "JetBrains Mono",
                                  "fontSize": 11,
                                  "fontWeight": "normal"
                                }
                              ]
                            },
                            {
                              "type": "text",
                              "id": "JCPVa",
                              "name": "q9a",
                              "fill": "#785E48",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "See CLI Reference for details.",
                              "lineHeight": 1.6,
                              "fontFamily": "Inter",
                              "fontSize": 14,
                              "fontWeight": "normal"
                            }
                          ]
                        },
                        {
                          "type": "frame",
                          "id": "1KMNs",
                          "name": "q10",
                          "width": "fill_container",
                          "layout": "vertical",
                          "gap": 12,
                          "children": [
                            {
                              "type": "text",
                              "id": "kc5y3",
                              "name": "q10h",
                              "fill": "#2D1F14",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "How do I increase the agent timeout?",
                              "fontFamily": "Space Grotesk",
                              "fontSize": 18,
                              "fontWeight": "600"
                            },
                            {
                              "type": "text",
                              "id": "gti7R",
                              "name": "q10a",
                              "fill": "#785E48",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "The default agent timeout is 300 seconds. For complex objectives or slow models, pass --timeout:",
                              "lineHeight": 1.6,
                              "fontFamily": "Inter",
                              "fontSize": 14,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "frame",
                              "id": "NMb1U",
                              "name": "codeBlock",
                              "width": "fill_container",
                              "fill": "#231A12",
                              "cornerRadius": 8,
                              "padding": [
                                8,
                                12
                              ],
                              "children": [
                                {
                                  "type": "text",
                                  "id": "hD9Nc",
                                  "name": "q10codeText",
                                  "fill": "#e8e6e3",
                                  "textGrowth": "fixed-width",
                                  "width": "fill_container",
                                  "content": "crucis run --timeout 600   # 10 minutes",
                                  "lineHeight": 1.5,
                                  "fontFamily": "JetBrains Mono",
                                  "fontSize": 11,
                                  "fontWeight": "normal"
                                }
                              ]
                            }
                          ]
                        },
                        {
                          "type": "frame",
                          "id": "uI5IC",
                          "name": "q11",
                          "width": "fill_container",
                          "layout": "vertical",
                          "gap": 12,
                          "children": [
                            {
                              "type": "text",
                              "id": "beF9M",
                              "name": "q11h",
                              "fill": "#2D1F14",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "Do I need to write constraint profiles?",
                              "fontFamily": "Space Grotesk",
                              "fontSize": 18,
                              "fontWeight": "600"
                            },
                            {
                              "type": "text",
                              "id": "jm3xD",
                              "name": "q11a",
                              "fill": "#785E48",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "No. Built-in defaults (default and recommended) are used when no constraints/profiles.yaml exists. You only need a custom profiles file if you want to adjust constraint thresholds. Constraints use a flat list format and are auto-classified as \"required\" (blocking) or \"advisory\" (non-blocking).",
                              "lineHeight": 1.6,
                              "fontFamily": "Inter",
                              "fontSize": 14,
                              "fontWeight": "normal"
                            }
                          ]
                        },
                        {
                          "type": "frame",
                          "id": "Ynwbo",
                          "name": "q13",
                          "width": "fill_container",
                          "layout": "vertical",
                          "gap": 12,
                          "children": [
                            {
                              "type": "text",
                              "id": "eIut3",
                              "name": "q13h",
                              "fill": "#2D1F14",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "How do I validate my objective?",
                              "fontFamily": "Space Grotesk",
                              "fontSize": 18,
                              "fontWeight": "600"
                            },
                            {
                              "type": "frame",
                              "id": "DKwW1",
                              "name": "codeBlock",
                              "width": "fill_container",
                              "fill": "#231A12",
                              "cornerRadius": 8,
                              "padding": [
                                8,
                                12
                              ],
                              "children": [
                                {
                                  "type": "text",
                                  "id": "CCFKl",
                                  "name": "q13codeText1",
                                  "fill": "#e8e6e3",
                                  "textGrowth": "fixed-width",
                                  "width": "fill_container",
                                  "content": "crucis validate objective.yaml",
                                  "lineHeight": 1.5,
                                  "fontFamily": "JetBrains Mono",
                                  "fontSize": 11,
                                  "fontWeight": "normal"
                                }
                              ]
                            },
                            {
                              "type": "text",
                              "id": "nlHzr",
                              "name": "q13a",
                              "fill": "#785E48",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "By default this runs structural checks and an LLM semantic review that verifies each eval's expected output against the described behavior. The agent streams its progress in real time.\n\nTo skip the LLM review and only run fast structural checks:",
                              "lineHeight": 1.6,
                              "fontFamily": "Inter",
                              "fontSize": 14,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "frame",
                              "id": "QOgeX",
                              "name": "codeBlock2",
                              "width": "fill_container",
                              "fill": "#231A12",
                              "cornerRadius": 8,
                              "padding": [
                                8,
                                12
                              ],
                              "children": [
                                {
                                  "type": "text",
                                  "id": "UJNq2",
                                  "name": "q13codeText2",
                                  "fill": "#e8e6e3",
                                  "textGrowth": "fixed-width",
                                  "width": "fill_container",
                                  "content": "crucis validate objective.yaml --static",
                                  "lineHeight": 1.5,
                                  "fontFamily": "JetBrains Mono",
                                  "fontSize": 11,
                                  "fontWeight": "normal"
                                }
                              ]
                            }
                          ]
                        },
                        {
                          "type": "frame",
                          "id": "jVAUz",
                          "name": "qCiCd",
                          "width": "fill_container",
                          "layout": "vertical",
                          "gap": 12,
                          "children": [
                            {
                              "type": "text",
                              "id": "JSTQn",
                              "name": "mCiCdQ",
                              "fill": "#2D1F14",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "Can I use Crucis in CI/CD?",
                              "fontFamily": "Space Grotesk",
                              "fontSize": 16,
                              "fontWeight": "600"
                            },
                            {
                              "type": "text",
                              "id": "Xjhq8",
                              "name": "mCiCdA",
                              "fill": "#785E48",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "Yes. Use crucis run --no-sandbox in your CI pipeline. The CLI exits with code 0 on success and non-zero on failure, making it straightforward to integrate with GitHub Actions, GitLab CI, or any CI system.",
                              "lineHeight": 1.6,
                              "fontFamily": "Inter",
                              "fontSize": 14,
                              "fontWeight": "normal"
                            }
                          ]
                        }
                      ]
                    },
