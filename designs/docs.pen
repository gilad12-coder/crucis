                    },
                    {
                      "type": "text",
                      "id": "4etdO",
                      "name": "intro2",
                      "fill": "#785E48",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "Add verified behavior to a project that already has source code. Crucis is an autonomy scaffold for code-generating agents -- it detects existing Python files and scaffolds accordingly.",
                      "lineHeight": 1.6,
                      "fontFamily": "Inter",
                      "fontSize": 14,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "frame",
                      "id": "guXbr",
                      "name": "section1",
                      "width": "fill_container",
                      "layout": "vertical",
                      "gap": 12,
                      "children": [
                        {
                          "type": "text",
                          "id": "Bn0X3",
                          "name": "s1h",
                          "fill": "#2D1F14",
                          "content": "1. Initialize in your project",
                          "fontFamily": "Space Grotesk",
                          "fontSize": 23,
                          "fontWeight": "600"
                        },
                        {
                          "type": "frame",
                          "id": "xSiKj",
                          "name": "codeBlock",
                          "width": "fill_container",
                          "fill": "#231A12",
                          "cornerRadius": 10,
                          "padding": [
                            16,
                            20
                          ],
                          "children": [
                            {
                              "type": "text",
                              "id": "0MqnM",
                              "name": "s1ct",
                              "fill": "#e8e6e3",
                              "content": "crucis init --existing-codebase --no-agent --name my_feature",
                              "lineHeight": 1.5,
                              "fontFamily": "JetBrains Mono",
                              "fontSize": 12.5,
                              "fontWeight": "normal"
                            }
                          ]
                        }
                      ]
                    },
                    {
                      "type": "frame",
                      "id": "CjYkq",
                      "name": "section2",
                      "width": "fill_container",
                      "layout": "vertical",
                      "gap": 12,
                      "children": [
                        {
                          "type": "text",
                          "id": "AHaMd",
                          "name": "s2h",
                          "fill": "#2D1F14",
                          "content": "2. Configure the objective",
                          "fontFamily": "Space Grotesk",
                          "fontSize": 23,
                          "fontWeight": "600"
                        },
                        {
                          "type": "frame",
                          "id": "HOPXw",
                          "name": "codeBlock",
                          "width": "fill_container",
                          "fill": "#231A12",
                          "cornerRadius": 10,
                          "padding": [
                            16,
                            20
                          ],
                          "children": [
                            {
                              "type": "text",
                              "id": "MIp4F",
                              "name": "s2ct",
                              "fill": "#e8e6e3",
                              "content": "name: my_feature\ndescription: >-\n  Parse configuration from YAML files and return validated settings.\nsignature: \"load_config(path: str) -> dict\"\nbehaviors:\n  - \"Parses YAML config files into validated dictionaries\"\n  - \"Returns empty dict for missing files instead of raising\"\ntests_constraint_profile: recommended\nimplementation_constraint_profile: default\ntarget_files:\n  - \"myproject/config.py\"\ncontext_files:\n  - \"myproject/models.py\"\n  - \"myproject/defaults.py\"\nexisting_tests:\n  - \"tests/test_models.py\"\nexamples:\n  - input: \"('config.yaml',)\"\n    output: \"{'debug': False, 'port': 8080}\"\n  - input: \"('missing.yaml',)\"\n    output: \"{}\"\ntasks:\n  - name: my_feature\n    description: Load and validate config from a YAML file path.\n    signature: \"load_config(path: str) -> dict\"\n    target_files:\n      - \"myproject/config.py\"\n    context_files:\n      - \"myproject/models.py\"\n    examples:\n      - input: \"('config.yaml',)\"\n        output: \"{'debug': False, 'port': 8080}\"\n      - input: \"('missing.yaml',)\"\n        output: \"{}\"",
                              "lineHeight": 1.5,
                              "fontFamily": "JetBrains Mono",
                              "fontSize": 12.5,
                              "fontWeight": "normal"
                            }
                          ]
                        }
                      ]
                    },
                    {
                      "type": "frame",
                      "id": "IiaGx",
                      "name": "section3",
                      "width": "fill_container",
                      "layout": "vertical",
                      "gap": 12,
                      "children": [
                        {
                          "type": "text",
                          "id": "bdzZS",
                          "name": "s3h",
                          "fill": "#2D1F14",
                          "content": "3. Configure the agent (optional)",
                          "fontFamily": "Space Grotesk",
                          "fontSize": 23,
                          "fontWeight": "600"
                        },
                        {
                          "type": "frame",
                          "id": "zCZVl",
                          "name": "codeBlock",
                          "width": "fill_container",
                          "fill": "#231A12",
                          "cornerRadius": 10,
                          "padding": [
                            16,
                            20
                          ],
                          "children": [
                            {
                              "type": "text",
                              "id": "OVIJZ",
                              "name": "s3ct",
                              "fill": "#e8e6e3",
                              "content": "agents:\n  generation_agent: codex    # or \"claude\"\n  generation_model: null     # null = agent default",
                              "lineHeight": 1.5,
                              "fontFamily": "JetBrains Mono",
                              "fontSize": 12.5,
                              "fontWeight": "normal"
                            }
                          ]
                        }
                      ]
                    },
                    {
                      "type": "frame",
                      "id": "0sJlj",
                      "name": "section4",
                      "width": "fill_container",
                      "layout": "vertical",
                      "gap": 12,
                      "children": [
                        {
                          "type": "text",
                          "id": "inEZV",
                          "name": "s4h",
                          "fill": "#2D1F14",
                          "content": "4. Run the pipeline",
                          "fontFamily": "Space Grotesk",
                          "fontSize": 23,
                          "fontWeight": "600"
                        },
                        {
                          "type": "frame",
                          "id": "LeGdu",
                          "name": "codeBlock",
                          "width": "fill_container",
                          "fill": "#231A12",
                          "cornerRadius": 10,
                          "padding": [
                            16,
                            20
                          ],
                          "children": [
                            {
                              "type": "text",
                              "id": "xWuHt",
                              "name": "s4ct",
                              "fill": "#e8e6e3",
                              "content": "crucis run --no-sandbox",
                              "lineHeight": 1.5,
                              "fontFamily": "JetBrains Mono",
                              "fontSize": 12.5,
                              "fontWeight": "normal"
                            }
                          ]
                        }
                      ]
