                              "fill": "#2D1F14",
                              "content": "API key not set",
                              "fontFamily": "Space Grotesk",
                              "fontSize": 18,
                              "fontWeight": "600"
                            },
                            {
                              "type": "frame",
                              "id": "xKq9J",
                              "name": "codeBlock3",
                              "width": "fill_container",
                              "fill": "#231A12",
                              "cornerRadius": 10,
                              "padding": [
                                16,
                                20
                              ],
                              "children": [
                                {
                                  "type": "text",
                                  "id": "R4ets",
                                  "name": "sub2codeText",
                                  "fill": "#e8e6e3",
                                  "content": "[WARN] api_key_claude: ANTHROPIC_API_KEY is not set (required by claude agent)",
                                  "lineHeight": 1.5,
                                  "fontFamily": "JetBrains Mono",
                                  "fontSize": 12.5,
                                  "fontWeight": "normal"
                                }
                              ]
                            },
                            {
                              "type": "text",
                              "id": "50lZ9",
                              "name": "sub2p",
                              "fill": "#785E48",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "Run crucis doctor to check API key status. Set the required key for your configured agent:",
                              "lineHeight": 1.6,
                              "fontFamily": "Inter",
                              "fontSize": 14,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "frame",
                              "id": "X65xL",
                              "name": "codeBlock4",
                              "width": "fill_container",
                              "fill": "#231A12",
                              "cornerRadius": 10,
                              "padding": [
                                16,
                                20
                              ],
                              "children": [
                                {
                                  "type": "text",
                                  "id": "ODXXF",
                                  "name": "sub2fixText",
                                  "fill": "#e8e6e3",
                                  "content": "export ANTHROPIC_API_KEY=sk-ant-...   # for claude agent\nexport OPENAI_API_KEY=sk-...          # for codex agent",
                                  "lineHeight": 1.5,
                                  "fontFamily": "JetBrains Mono",
                                  "fontSize": 12.5,
                                  "fontWeight": "normal"
                                }
                              ]
                            },
                            {
                              "type": "text",
                              "id": "kuxRp",
                              "name": "sub2note",
                              "fill": "#785E48",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "For Codex, codex login also satisfies authentication checks even when OPENAI_API_KEY is unset.\n\nAlternatively, configure a different agent in .crucis/settings.yaml:",
                              "lineHeight": 1.6,
                              "fontFamily": "Inter",
                              "fontSize": 14,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "frame",
                              "id": "f8JEB",
                              "name": "codeBlock4b",
                              "width": "fill_container",
                              "fill": "#231A12",
                              "cornerRadius": 10,
                              "padding": [
                                16,
                                20
                              ],
                              "children": [
                                {
                                  "type": "text",
                                  "id": "0lBqA",
                                  "name": "sub2yamlText",
                                  "fill": "#e8e6e3",
                                  "content": "agents:\n  generation_agent: codex",
                                  "lineHeight": 1.5,
                                  "fontFamily": "JetBrains Mono",
                                  "fontSize": 12.5,
                                  "fontWeight": "normal"
                                }
                              ]
                            }
                          ]
                        }
                      ]
                    },
