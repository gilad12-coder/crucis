                    {
                      "type": "frame",
                      "id": "WQzwW",
                      "name": "sectionInit",
                      "width": "fill_container",
                      "layout": "vertical",
                      "gap": 12,
                      "children": [
                        {
                          "type": "text",
                          "id": "zu4Uo",
                          "name": "s5h",
                          "fill": "#2D1F14",
                          "content": "What crucis init creates",
                          "fontFamily": "Space Grotesk",
                          "fontSize": 23,
                          "fontWeight": "600"
                        },
                        {
                          "type": "text",
                          "id": "Sf0dy",
                          "name": "s5p",
                          "fill": "#785E48",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "By default, crucis init creates only two files: objective.yaml and src/solution.py. Profiles and settings are optional — add them with --with-profiles or --with-settings. Settings are auto-created on first crucis run if they don't exist.",
                          "lineHeight": 1.6,
                          "fontFamily": "Inter",
                          "fontSize": 14,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "1DqeV",
                          "name": "holdoutPara",
                          "fill": "#785E48",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "You don't need to manually split examples into train and holdout sets. Just list your examples under examples: and Crucis automatically holds out the last ~20% for verification. If you need manual control, you can still use an explicit holdout: field. Use holdout: [] to opt out of holdout verification entirely.",
                          "lineHeight": 1.6,
                          "fontFamily": "Inter",
                          "fontSize": 14,
                          "fontWeight": "normal"
                        }
                      ]
                    },
