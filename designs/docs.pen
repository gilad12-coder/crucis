                              "type": "text",
                              "id": "Ix1If",
                              "fill": "#785E48",
                              "content": "1. Python 3.10+ (3.12+ recommended)",
                              "fontFamily": "Inter",
                              "fontSize": 14,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "text",
                              "id": "zNjoy",
                              "fill": "#785E48",
                              "content": "2. An agent CLI on your PATH — either claude or codex",
                              "fontFamily": "Inter",
                              "fontSize": 14,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "text",
                              "id": "LEJeB",
                              "fill": "#785E48",
                              "content": "3. An API key — ANTHROPIC_API_KEY for Claude, or OPENAI_API_KEY / codex login for Codex",
