                          "name": "p5",
                          "fill": "#785E48",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "Generate and verify multiple related endpoint handlers in one objective. Each task maps to one handler function, all sharing the same target file.",
                          "lineHeight": 1.6,
                          "fontFamily": "Inter",
                          "fontSize": 14,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "frame",
                          "id": "81x6r",
                          "name": "codeBlock",
                          "width": "fill_container",
                          "fill": "#231A12",
                          "cornerRadius": 10,
                          "padding": [
                            16,
                            20
                          ],
                          "children": [
                            {
                              "type": "text",
                              "id": "uBINw",
                              "name": "code5t",
                              "fill": "#e8e6e3",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "behaviors:\n  - \"Users are assigned sequential integer IDs\"\n  - \"Created users are retrievable by ID\"\ntasks:\n  - name: create_user\n    description: Create a new user and return the user dict.\n    target_files: [\"src/handlers.py\"]\n    examples:\n      - input: \"({'name': 'alice'},)\"\n        output: \"{'id': 1, 'name': 'alice'}\"\n  - name: get_user\n    description: Retrieve a user by ID.\n    target_files: [\"src/handlers.py\"]\n    examples:\n      - input: \"(1,)\"\n        output: \"{'id': 1, 'name': 'alice'}\"",
                              "lineHeight": 1.5,
                              "fontFamily": "JetBrains Mono",
                              "fontSize": 12.5,
                              "fontWeight": "normal"
                            }
                          ]
                        },
                        {
                          "type": "text",
                          "id": "cwunG",
                          "name": "holdoutText",
                          "fill": "#785E48",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "Just write examples: -- the last ~20% are automatically held out as hidden evals.",
                          "lineHeight": 1.6,
                          "fontFamily": "Inter",
                          "fontSize": 14,
                          "fontWeight": "normal"
                        },
