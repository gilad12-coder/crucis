                      "gap": 12,
                      "children": [
                        {
                          "type": "text",
                          "id": "8Aolz",
                          "name": "conceptsH2",
                          "fill": "#2D1F14",
                          "content": "Concepts",
                          "fontFamily": "Space Grotesk",
                          "fontSize": 23,
                          "fontWeight": "600"
                        },
                        {
                          "type": "frame",
                          "id": "bAvVn",
                          "name": "defList",
                          "width": "fill_container",
                          "layout": "vertical",
                          "gap": 10,
                          "padding": [
                            0,
                            0,
                            0,
                            8
                          ],
                          "children": [
                            {
                              "type": "frame",
                              "id": "Y1VuP",
                              "name": "df1",
                              "width": "fill_container",
                              "children": [
                                {
                                  "type": "text",
                                  "id": "droY7",
                                  "name": "df1t",
                                  "fill": "#2D1F14",
                                  "content": "Scaffold",
                                  "lineHeight": 1.6,
                                  "fontFamily": "Inter",
                                  "fontSize": 14,
                                  "fontWeight": "600"
                                },
                                {
                                  "type": "text",
                                  "id": "mKNaI",
                                  "name": "df1d",
                                  "fill": "#785E48",
                                  "textGrowth": "fixed-width",
                                  "width": "fill_container",
                                  "content": " — The workspace initialization created by crucis init. By default generates only objective.yaml and src/solution.py (for new-project scaffolds). Use --with-profiles to also create constraints/profiles.yaml and --with-settings to also create .crucis/settings.yaml. Existing codebases are auto-detected or forced via --existing-codebase.",
                                  "lineHeight": 1.6,
                                  "fontFamily": "Inter",
                                  "fontSize": 14,
                                  "fontWeight": "normal"
                                }
                              ]
                            },
                            {
                              "type": "frame",
                              "id": "EbAVi",
                              "name": "dfPlan",
                              "width": "fill_container",
                              "children": [
                                {
                                  "type": "text",
                                  "id": "fj3iZ",
                                  "name": "dfPlanT",
                                  "fill": "#2D1F14",
                                  "content": "Plan",
                                  "lineHeight": 1.6,
                                  "fontFamily": "Inter",
                                  "fontSize": 14,
                                  "fontWeight": "600"
                                },
                                {
                                  "type": "text",
                                  "id": "vL4dR",
                                  "name": "dfPlanD",
                                  "fill": "#785E48",
                                  "textGrowth": "fixed-width",
                                  "width": "fill_container",
                                  "content": " — A structured generation plan created by crucis run --plan. Written to plan.md in the workspace root. Guides the test generation agent with per-task file structure, test categories, and constraint compliance instructions.",
                                  "lineHeight": 1.6,
                                  "fontFamily": "Inter",
                                  "fontSize": 14,
                                  "fontWeight": "normal"
                                }
                              ]
                            },
                            {
                              "type": "frame",
                              "id": "boLk1",
                              "name": "df2",
                              "width": "fill_container",
                              "children": [
                                {
                                  "type": "text",
                                  "id": "i8tAb",
                                  "name": "df2t",
                                  "fill": "#2D1F14",
                                  "content": "Objective",
                                  "lineHeight": 1.6,
                                  "fontFamily": "Inter",
                                  "fontSize": 14,
                                  "fontWeight": "600"
                                },
                                {
                                  "type": "text",
                                  "id": "5J4HR",
                                  "name": "df2d",
                                  "fill": "#785E48",
                                  "textGrowth": "fixed-width",
                                  "width": "fill_container",
                                  "content": " — A YAML file defining what Crucis should build. Contains a name, description, train evals, holdout evals, constraints, target files, and optional behaviors. Can be single-task or multi-task. See Objective Format Reference.",
                                  "lineHeight": 1.6,
                                  "fontFamily": "Inter",
                                  "fontSize": 14,
                                  "fontWeight": "normal"
                                }
                              ]
                            },
                            {
                              "type": "frame",
                              "id": "9Gn67",
                              "name": "df3",
                              "width": "fill_container",
                              "children": [
                                {
                                  "type": "text",
                                  "id": "QfjhE",
                                  "name": "df3t",
                                  "fill": "#2D1F14",
                                  "content": "Task",
                                  "lineHeight": 1.6,
                                  "fontFamily": "Inter",
                                  "fontSize": 14,
                                  "fontWeight": "600"
                                },
                                {
                                  "type": "text",
                                  "id": "YJSxY",
                                  "name": "df3d",
                                  "fill": "#785E48",
                                  "textGrowth": "fixed-width",
                                  "width": "fill_container",
                                  "content": " — One unit of work within an objective. Each task has its own name, signature, evals, constraint profile, and optional behaviors. Multi-task objectives list tasks under the tasks key.",
                                  "lineHeight": 1.6,
                                  "fontFamily": "Inter",
                                  "fontSize": 14,
                                  "fontWeight": "normal"
                                }
                              ]
                            },
                            {
                              "type": "frame",
                              "id": "iq6hX",
                              "name": "dfBehav",
                              "width": "fill_container",
                              "children": [
                                {
                                  "type": "text",
                                  "id": "7V4xl",
                                  "name": "dfBehavT",
                                  "fill": "#2D1F14",
                                  "content": "Behaviors",
                                  "lineHeight": 1.6,
                                  "fontFamily": "Inter",
                                  "fontSize": 14,
                                  "fontWeight": "600"
                                },
                                {
                                  "type": "text",
                                  "id": "x58YI",
                                  "name": "dfBehavD",
                                  "fill": "#785E48",
                                  "textGrowth": "fixed-width",
                                  "width": "fill_container",
                                  "content": " — An optional list[str] on objectives and tasks describing expected behavioral properties (e.g. &quot;idempotent&quot;, &quot;thread-safe&quot;, &quot;deterministic&quot;). Used to guide test generation and adversarial review.",
                                  "lineHeight": 1.6,
                                  "fontFamily": "Inter",
                                  "fontSize": 14,
                                  "fontWeight": "normal"
                                }
                              ]
                            },
                            {
                              "type": "frame",
                              "id": "DJKwc",
                              "name": "df4",
                              "width": "fill_container",
                              "children": [
                                {
                                  "type": "text",
                                  "id": "zCVL5",
                                  "name": "df4t",
                                  "fill": "#2D1F14",
                                  "content": "Train Evals",
                                  "lineHeight": 1.6,
                                  "fontFamily": "Inter",
                                  "fontSize": 14,
                                  "fontWeight": "600"
                                },
                                {
                                  "type": "text",
                                  "id": "N1OHg",
                                  "name": "df4d",
                                  "fill": "#785E48",
                                  "content": " — Visible input/output pairs used during test generation and adversarial review. Agents see these evals and use them to build pytest suites.",
                                  "lineHeight": 1.6,
                                  "fontFamily": "Inter",
                                  "fontSize": 14,
                                  "fontWeight": "normal"
                                }
                              ]
                            },
                            {
                              "type": "frame",
                              "id": "zbpDx",
                              "name": "df5",
                              "width": "fill_container",
                              "children": [
                                {
                                  "type": "text",
                                  "id": "eB3cm",
                                  "name": "df5t",
                                  "fill": "#2D1F14",
                                  "content": "Holdout Evals",
                                  "lineHeight": 1.6,
                                  "fontFamily": "Inter",
                                  "fontSize": 14,
                                  "fontWeight": "600"
                                },
                                {
                                  "type": "text",
                                  "id": "D2uVb",
                                  "name": "df5d",
                                  "fill": "#785E48",
                                  "textGrowth": "fixed-width",
                                  "width": "fill_container",
                                  "content": " — Hidden input/output pairs never shown to any agent. Used only during final verification to ensure the implementation generalizes beyond known inputs. Failures are reported as counts only -- no payloads are leaked.",
                                  "lineHeight": 1.6,
                                  "fontFamily": "Inter",
                                  "fontSize": 14,
                                  "fontWeight": "normal"
                                }
                              ]
                            },
                            {
                              "type": "frame",
                              "id": "fPIdM",
                              "name": "dfAutoH",
                              "width": "fill_container",
                              "children": [
                                {
                                  "type": "text",
                                  "id": "4V7OV",
                                  "name": "dfAutoHT",
                                  "fill": "#2D1F14",
                                  "content": "Auto-Holdout",
                                  "lineHeight": 1.6,
                                  "fontFamily": "Inter",
                                  "fontSize": 14,
                                  "fontWeight": "600"
                                },
                                {
                                  "type": "text",
                                  "id": "vdb1o",
                                  "name": "dfAutoHD",
                                  "fill": "#785E48",
                                  "textGrowth": "fixed-width",
                                  "width": "fill_container",
                                  "content": " — When only examples (or train_evals) are provided without a holdout_evals key, Crucis automatically splits the last ~20% as holdout evals. To provide explicit holdout evals, add a holdout: key. To opt out of auto-holdout, set holdout: [].",
                                  "lineHeight": 1.6,
                                  "fontFamily": "Inter",
                                  "fontSize": 14,
                                  "fontWeight": "normal"
                                }
                              ]
                            },
                            {
                              "type": "frame",
                              "id": "EO2a5",
                              "name": "df6",
                              "width": "fill_container",
                              "children": [
                                {
                                  "type": "text",
                                  "id": "gUY5y",
                                  "name": "df6t",
                                  "fill": "#2D1F14",
                                  "content": "Train Suite",
                                  "lineHeight": 1.6,
                                  "fontFamily": "Inter",
                                  "fontSize": 14,
                                  "fontWeight": "600"
                                },
                                {
                                  "type": "text",
                                  "id": "b4fDk",
                                  "name": "df6d",
                                  "fill": "#785E48",
                                  "textGrowth": "fixed-width",
                                  "width": "fill_container",
                                  "content": " — A generated pytest file containing tests for a task. Built by the generation agent from the objective, constraints, and train evals. Must pass syntax validation and constraint checks before approval.",
                                  "lineHeight": 1.6,
                                  "fontFamily": "Inter",
                                  "fontSize": 14,
                                  "fontWeight": "normal"
                                }
                              ]
                            },
                            {
                              "type": "frame",
                              "id": "Dw4rM",
                              "name": "df7",
                              "width": "fill_container",
                              "children": [
                                {
                                  "type": "text",
                                  "id": "nGIX0",
                                  "name": "df7t",
                                  "fill": "#2D1F14",
                                  "content": "Constraint Profile",
                                  "lineHeight": 1.6,
                                  "fontFamily": "Inter",
                                  "fontSize": 14,
                                  "fontWeight": "600"
                                },
                                {
                                  "type": "text",
                                  "id": "CIG5M",
                                  "name": "df7d",
                                  "fill": "#785E48",
                                  "textGrowth": "fixed-width",
                                  "width": "fill_container",
                                  "content": " — A named set of constraints defined in constraints/profiles.yaml. Constraints are listed flat and auto-classified into required (blocking) or advisory based on the field type. The old nested primary:/secondary: format still works. Referenced by name in the objective YAML via tests_constraint_profile and implementation_constraint_profile. See Constraints Reference.",
                                  "lineHeight": 1.6,
                                  "fontFamily": "Inter",
                                  "fontSize": 14,
                                  "fontWeight": "normal"
                                }
                              ]
                            },
                            {
                              "type": "frame",
                              "id": "PLMjg",
                              "name": "dfReqC",
                              "width": "fill_container",
                              "children": [
                                {
                                  "type": "text",
                                  "id": "sdqoA",
                                  "name": "dfReqCT",
                                  "fill": "#2D1F14",
                                  "content": "Required Constraints",
                                  "lineHeight": 1.6,
                                  "fontFamily": "Inter",
                                  "fontSize": 14,
                                  "fontWeight": "600"
                                },
                                {
                                  "type": "text",
                                  "id": "4LEXM",
                                  "name": "dfReqCD",
                                  "fill": "#785E48",
                                  "textGrowth": "fixed-width",
                                  "width": "fill_container",
                                  "content": " — Hard gates -- if violated, the train suite is rejected and regenerated. Violations are fed back to the generation prompt. Most constraints are required by default.",
                                  "lineHeight": 1.6,
                                  "fontFamily": "Inter",
                                  "fontSize": 14,
                                  "fontWeight": "normal"
                                }
                              ]
                            },
                            {
                              "type": "frame",
                              "id": "T8opG",
                              "name": "dfAdvC",
                              "width": "fill_container",
                              "children": [
                                {
                                  "type": "text",
                                  "id": "maMqE",
                                  "name": "dfAdvCT",
                                  "fill": "#2D1F14",
                                  "content": "Advisory Constraints",
                                  "lineHeight": 1.6,
                                  "fontFamily": "Inter",
                                  "fontSize": 14,
                                  "fontWeight": "600"
                                },
                                {
                                  "type": "text",
                                  "id": "g7zia",
                                  "name": "dfAdvCD",
                                  "fill": "#785E48",
                                  "textGrowth": "fixed-width",
                                  "width": "fill_container",
                                  "content": " — Soft gates -- violations are reported but don't block approval. Checked only after required constraints pass. Advisory fields: require_docstrings, no_print_statements, no_debugger_statements, no_global_state, require_type_annotations, no_nested_imports, no_star_imports, max_local_variables.",
                                  "lineHeight": 1.6,
                                  "fontFamily": "Inter",
                                  "fontSize": 14,
                                  "fontWeight": "normal"
                                }
                              ]
                            },
                            {
                              "type": "frame",
                              "id": "CQe6n",
                              "name": "df8",
                              "width": "fill_container",
                              "children": [
                                {
                                  "type": "text",
                                  "id": "qQup0",
                                  "name": "df8t",
                                  "fill": "#2D1F14",
                                  "content": "Adversarial Review",
                                  "lineHeight": 1.6,
                                  "fontFamily": "Inter",
                                  "fontSize": 14,
                                  "fontWeight": "600"
                                },
                                {
                                  "type": "text",
                                  "id": "M9fLv",
                                  "name": "df8d",
                                  "fill": "#785E48",
                                  "textGrowth": "fixed-width",
                                  "width": "fill_container",
                                  "content": " — The critic agent analyzes a train suite for weaknesses. Returns a JSON report with attack vectors, generalization gaps, and suggested probe tests.",
                                  "lineHeight": 1.6,
                                  "fontFamily": "Inter",
                                  "fontSize": 14,
                                  "fontWeight": "normal"
                                }
                              ]
                            },
                            {
                              "type": "frame",
                              "id": "frZHK",
                              "name": "df9",
                              "width": "fill_container",
                              "children": [
                                {
                                  "type": "text",
                                  "id": "SMfjn",
                                  "name": "df9t",
                                  "fill": "#2D1F14",
                                  "content": "Cheating Probe",
                                  "lineHeight": 1.6,
                                  "fontFamily": "Inter",
                                  "fontSize": 14,
                                  "fontWeight": "600"
                                },
                                {
                                  "type": "text",
                                  "id": "jY8H4",
                                  "name": "df9d",
                                  "fill": "#785E48",
                                  "textGrowth": "fixed-width",
                                  "width": "fill_container",
                                  "content": " — A deliberately cheating implementation generated to test whether the train suite can be passed by hardcoding, fingerprinting inputs, or using lookup tables. If the probe passes, the tests have gaps.",
                                  "lineHeight": 1.6,
                                  "fontFamily": "Inter",
                                  "fontSize": 14,
                                  "fontWeight": "normal"
                                }
                              ]
                            },
                            {
                              "type": "frame",
                              "id": "n3gxT",
                              "name": "df10",
                              "width": "fill_container",
                              "children": [
                                {
                                  "type": "text",
                                  "id": "EX77j",
                                  "name": "df10t",
                                  "fill": "#2D1F14",
                                  "content": "Checkpoint",
                                  "lineHeight": 1.6,
                                  "fontFamily": "Inter",
                                  "fontSize": 14,
                                  "fontWeight": "600"
                                },
                                {
                                  "type": "text",
                                  "id": "g6oZg",
                                  "name": "df10d",
                                  "fill": "#785E48",
                                  "textGrowth": "fixed-width",
                                  "width": "fill_container",
                                  "content": " — A JSON file (.checkpoint.json) that persists progress across runs. Tracks each task's state, approved train suite source, adversarial report, and evaluation_passed status. Allows resuming interrupted runs. Use crucis run --reset to clear the entire checkpoint or --reset-task <name> to clear specific tasks.",
                                  "lineHeight": 1.6,
                                  "fontFamily": "Inter",
                                  "fontSize": 14,
                                  "fontWeight": "normal"
                                }
                              ]
                            },
                            {
                              "type": "frame",
                              "id": "WouJc",
                              "name": "df11",
                              "width": "fill_container",
                              "children": [
                                {
                                  "type": "text",
                                  "id": "G0EzN",
                                  "name": "df11t",
                                  "fill": "#2D1F14",
                                  "content": "Curriculum",
                                  "lineHeight": 1.6,
                                  "fontFamily": "Inter",
                                  "fontSize": 14,
                                  "fontWeight": "600"
                                },
                                {
                                  "type": "text",
                                  "id": "RArKt",
                                  "name": "df11d",
                                  "fill": "#785E48",
                                  "textGrowth": "fixed-width",
                                  "width": "fill_container",
                                  "content": " — A markdown file generated during evaluation containing the objective metadata, target files, test paths, and per-task details. This is the primary context sent to the implementation agent.",
                                  "lineHeight": 1.6,
                                  "fontFamily": "Inter",
                                  "fontSize": 14,
                                  "fontWeight": "normal"
                                }
                              ]
                            },
                            {
                              "type": "frame",
                              "id": "3aU2s",
                              "name": "df12",
                              "width": "fill_container",
                              "children": [
                                {
                                  "type": "text",
                                  "id": "E7Tm8",
                                  "name": "df12t",
                                  "fill": "#2D1F14",
                                  "content": "Sandbox",
                                  "lineHeight": 1.6,
                                  "fontFamily": "Inter",
                                  "fontSize": 14,
                                  "fontWeight": "600"
                                },
                                {
                                  "type": "text",
                                  "id": "B0PcA",
                                  "name": "df12d",
                                  "fill": "#785E48",
                                  "textGrowth": "fixed-width",
                                  "width": "fill_container",
                                  "content": " — Docker-isolated pytest execution. Tests run inside a container to prevent generated code from affecting the host. Falls back to host pytest if Docker is unavailable.",
                                  "lineHeight": 1.6,
                                  "fontFamily": "Inter",
                                  "fontSize": 14,
                                  "fontWeight": "normal"
                                }
                              ]
                            },
                            {
                              "type": "frame",
                              "id": "6kPIO",
                              "name": "dfVerG",
                              "width": "fill_container",
                              "children": [
                                {
                                  "type": "text",
                                  "id": "h8dYD",
                                  "name": "dfVerGT",
                                  "fill": "#2D1F14",
                                  "content": "Verification Granularity",
                                  "lineHeight": 1.6,
                                  "fontFamily": "Inter",
                                  "fontSize": 14,
                                  "fontWeight": "600"
                                },
                                {
                                  "type": "text",
                                  "id": "udPFI",
                                  "name": "dfVerGD",
                                  "fill": "#785E48",
                                  "textGrowth": "fixed-width",
                                  "width": "fill_container",
                                  "content": " — Controls how tests are verified: task (default) runs each task's tests independently; objective runs all tasks' tests together in a single pytest invocation.",
                                  "lineHeight": 1.6,
                                  "fontFamily": "Inter",
                                  "fontSize": 14,
                                  "fontWeight": "normal"
                                }
                              ]
                            },
                            {
                              "type": "frame",
                              "id": "0GjBQ",
                              "name": "dfBgOpt",
                              "width": "fill_container",
                              "children": [
                                {
                                  "type": "text",
                                  "id": "w5Wr7",
                                  "name": "dfBgOptT",
                                  "fill": "#2D1F14",
                                  "content": "Background Optimizer",
                                  "lineHeight": 1.6,
                                  "fontFamily": "Inter",
                                  "fontSize": 14,
                                  "fontWeight": "600"
                                },
                                {
                                  "type": "text",
                                  "id": "pZcNb",
                                  "name": "dfBgOptD",
                                  "fill": "#785E48",
                                  "textGrowth": "fixed-width",
                                  "width": "fill_container",
                                  "content": " — An experimental GEPA-powered system that improves prompt steering over time. Disabled by default; enable with optimizer: enabled: true in .crucis/settings.yaml. After successful evaluation, a background worker scores candidate policies and promotes winners. See Background Optimizer.",
                                  "lineHeight": 1.6,
                                  "fontFamily": "Inter",
                                  "fontSize": 14,
                                  "fontWeight": "normal"
                                }
                              ]
                            },
                            {
                              "type": "frame",
                              "id": "dbama",
                              "name": "dfPolicy",
                              "width": "fill_container",
                              "children": [
                                {
                                  "type": "text",
                                  "id": "0HjXo",
                                  "name": "dfPolicyT",
                                  "fill": "#2D1F14",
                                  "content": "Policy",
                                  "lineHeight": 1.6,
                                  "fontFamily": "Inter",
                                  "fontSize": 14,
                                  "fontWeight": "600"
                                },
                                {
                                  "type": "text",
                                  "id": "bXxOG",
                                  "name": "dfPolicyD",
                                  "fill": "#785E48",
                                  "textGrowth": "fixed-width",
                                  "width": "fill_container",
                                  "content": " — An optimizer policy that steers Crucis prompts. Contains four fields: repository_skill, generation_directives, adversary_directives, evaluation_directives. Each is injected into the corresponding prompt builder.",
                                  "lineHeight": 1.6,
                                  "fontFamily": "Inter",
                                  "fontSize": 14,
                                  "fontWeight": "normal"
                                }
                              ]
                            },
                            {
                              "type": "frame",
                              "id": "ZF3e1",
                              "name": "dfPromo",
                              "width": "fill_container",
                              "children": [
                                {
                                  "type": "text",
                                  "id": "DQ93Y",
                                  "name": "dfPromoT",
                                  "fill": "#2D1F14",
                                  "content": "Promotion",
                                  "lineHeight": 1.6,
                                  "fontFamily": "Inter",
                                  "fontSize": 14,
                                  "fontWeight": "600"
                                },
                                {
                                  "type": "text",
                                  "id": "XmbR0",
                                  "name": "dfPromoD",
                                  "fill": "#785E48",
                                  "content": " — Replacing the active optimizer policy with a winning candidate. Can be manual (crucis promote) or automatic (promotion_mode: auto).",
                                  "lineHeight": 1.6,
                                  "fontFamily": "Inter",
                                  "fontSize": 14,
                                  "fontWeight": "normal"
                                }
                              ]
                            }
                          ]
                        }
                      ]
                    },
