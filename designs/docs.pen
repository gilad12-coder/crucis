                          "fill": "#785E48",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "An optimizer policy steers Crucis prompts at three stages:",
                          "lineHeight": 1.6,
                          "fontFamily": "Inter",
                          "fontSize": 14,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "frame",
