                    {
                      "type": "text",
                      "id": "iriv2",
                      "name": "h2ws",
                      "fill": "#2D1F14",
                      "content": "Workspace Settings",
                      "fontFamily": "Space Grotesk",
                      "fontSize": 18,
                      "fontWeight": "600"
                    },
                    {
                      "type": "text",
                      "id": "akpjy",
                      "name": "wsIntro",
                      "fill": "#785E48",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "Crucis maintains a workspace-local settings file at .crucis/settings.yaml, created by crucis init or automatically on first run.",
                      "lineHeight": 1.6,
                      "fontFamily": "Inter",
                      "fontSize": 14,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "duMbd",
                      "name": "h3opt",
                      "fill": "#2D1F14",
                      "content": "Optimizer Settings",
                      "fontFamily": "Space Grotesk",
                      "fontSize": 18,
                      "fontWeight": "600"
                    },
                    {
                      "type": "text",
                      "id": "qBj9H",
                      "name": "optIntro",
                      "fill": "#785E48",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "The optimizer is disabled by default. To enable it, add optimizer: enabled: true to .crucis/settings.yaml:",
                      "lineHeight": 1.6,
                      "fontFamily": "Inter",
                      "fontSize": 14,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "frame",
                      "id": "L5CAw",
                      "name": "cbOpt",
                      "width": "fill_container",
                      "fill": "#231A12",
                      "cornerRadius": 10,
                      "padding": [
                        8,
                        12
                      ],
                      "children": [
                        {
                          "type": "text",
                          "id": "BySbI",
                          "fill": "#e8e6e3",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "schema_version: 1\noptimizer:\n  enabled: true\n  max_metric_calls: 24\n  reflection_lm: openai/gpt-5.2\n  train_split_ratio: 0.7\n  max_examples_per_run: 24\n  evaluator_timeout_sec: 180\n  pass_weight: 0.9\n  speed_weight: 0.1\n  min_score_delta: 0.01\n  promotion_mode: manual\n  queue_max_jobs: 64\n  capture_stdio: true",
                          "lineHeight": 1.5,
                          "fontFamily": "JetBrains Mono",
                          "fontSize": 11,
                          "fontWeight": "normal"
                        }
                      ]
                    },
                    {
                      "type": "text",
                      "id": "KceAZ",
                      "name": "optNote",
                      "fill": "#785E48",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "When the optimizer is disabled (the default), crucis init does not include the optimizer block in settings.yaml. The minimal default settings.yaml is:",
                      "lineHeight": 1.6,
                      "fontFamily": "Inter",
                      "fontSize": 14,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "frame",
                      "id": "8PAjt",
                      "name": "cbOptMin",
                      "width": "fill_container",
                      "fill": "#231A12",
                      "cornerRadius": 10,
                      "padding": [
                        8,
                        12
                      ],
                      "children": [
                        {
                          "type": "text",
                          "id": "lrQRV",
                          "fill": "#e8e6e3",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "schema_version: 1",
                          "lineHeight": 1.5,
                          "fontFamily": "JetBrains Mono",
                          "fontSize": 11,
                          "fontWeight": "normal"
                        }
                      ]
                    },
                    {
                      "type": "text",
                      "id": "2JKqM",
                      "name": "optBudget",
                      "fill": "#785E48",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "max_metric_calls is intentionally user-controlled here so budget can be tuned per workspace without changing CLI commands.",
                      "lineHeight": 1.6,
                      "fontFamily": "Inter",
                      "fontSize": 14,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "9UYJs",
                      "name": "h3agents",
                      "fill": "#2D1F14",
                      "content": "Agent Settings",
                      "fontFamily": "Space Grotesk",
                      "fontSize": 18,
                      "fontWeight": "600"
                    },
                    {
                      "type": "text",
                      "id": "jDbPs",
                      "name": "agentIntro",
                      "fill": "#785E48",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "Agent settings in .crucis/settings.yaml override environment variables when set:",
                      "lineHeight": 1.6,
                      "fontFamily": "Inter",
                      "fontSize": 14,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "frame",
                      "id": "X6HTX",
                      "name": "cb2",
                      "width": "fill_container",
                      "fill": "#231A12",
                      "cornerRadius": 10,
                      "padding": [
                        8,
                        12
                      ],
                      "children": [
                        {
                          "type": "text",
                          "id": "1ofZJ",
                          "fill": "#e8e6e3",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "agents:\n  generation_agent: null   # \"claude\" or \"codex\" (null = env var or default)\n  generation_model: null   # e.g. \"claude-opus-4-6\", \"o4-mini\"\n  critic_agent: null\n  critic_model: null\n  implementation_agent: null\n  implementation_model: null\n  max_iterations: null     # max generation/evaluation retries (null = 10)\n  max_budget_usd: null     # per-agent call budget cap (null = 5.00)",
                          "lineHeight": 1.5,
                          "fontFamily": "JetBrains Mono",
                          "fontSize": 11,
                          "fontWeight": "normal"
                        }
                      ]
                    },
