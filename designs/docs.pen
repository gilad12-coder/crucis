                          "name": "sec1h",
                          "fill": "#2D1F14",
                          "content": "1. Create a workspace",
                          "fontFamily": "Space Grotesk",
                          "fontSize": 18,
                          "fontWeight": "600"
                        },
                        {
                          "type": "frame",
                          "id": "AwK0w",
