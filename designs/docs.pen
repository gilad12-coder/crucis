                      "fill": "#EDE0CC",
                      "cornerRadius": 12,
                      "gap": 6,
                      "padding": [
                        4,
                        12
                      ],
                      "alignItems": "center",
                      "children": [
                        {
                          "type": "icon_font",
                          "id": "j5pJq",
                          "name": "ic9",
                          "width": 14,
                          "height": 14,
                          "iconFontFamily": "Material Symbols Rounded",
                          "fill": "#785E48"
                        },
                        {
                          "type": "text",
                          "id": "Z4c8X",
                          "name": "tx9",
                          "fill": "#785E48",
                          "content": "~5 min read",
                          "fontFamily": "Inter",
                          "fontSize": 12,
                          "fontWeight": "500"
                        }
                      ]
                    },
                    {
                      "type": "text",
                      "id": "DLBoP",
                      "name": "intro2",
                      "fill": "#785E48",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "Crucis is an autonomy scaffold that generates, attacks, and validates code through a pipeline of LLM agents and static analysis, providing structured automated feedback so agents can iterate without human intervention.",
                      "lineHeight": 1.6,
                      "fontFamily": "Inter",
                      "fontSize": 14,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "frame",
                      "id": "BjVHy",
                      "name": "sectionDataFlow",
                      "width": "fill_container",
                      "layout": "vertical",
                      "gap": 12,
                      "children": [
                        {
                          "type": "text",
                          "id": "K2haO",
                          "name": "h2df",
                          "fill": "#2D1F14",
                          "content": "Data Flow",
                          "fontFamily": "Space Grotesk",
                          "fontSize": 23,
                          "fontWeight": "600"
                        },
                        {
                          "type": "frame",
                          "id": "1rr4d",
                          "name": "numberedList",
                          "width": "fill_container",
                          "layout": "vertical",
                          "gap": 6,
                          "padding": [
                            0,
                            0,
                            0,
                            8
                          ],
                          "children": [
                            {
                              "type": "text",
                              "id": "0gOEr",
                              "name": "li1",
                              "fill": "#785E48",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "1.  Objective intake — intake/objective.py parses the YAML objective, validates eval expressions, resolves constraint profiles via constraints/loader.py. Constraints can be listed flat — the constraint registry auto-classifies them into required (blocking) vs advisory.",
                              "lineHeight": 1.6,
                              "fontFamily": "Inter",
                              "fontSize": 14,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "text",
                              "id": "x5QZN",
                              "name": "li2",
                              "fill": "#785E48",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "2.  Fit phase — core/loop.py iterates through each task: generates pytest train suites via the generation agent, validates syntax (AST parse) and constraints (static analysis), runs adversarial review (attack vectors, generalization gaps), generates and executes a cheating probe, and saves progress to checkpoint after each task.",
                              "lineHeight": 1.6,
                              "fontFamily": "Inter",
                              "fontSize": 14,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "text",
                              "id": "cdvVC",
                              "name": "li3",
                              "fill": "#785E48",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "3.  Evaluation phase — core/loop.py orchestrates implementation: builds a curriculum from checkpoint data, sends curriculum + test files to the implementation agent, runs pytest in Docker sandbox (or host fallback), verifies against hidden holdout evals, retries up to max_iterations on failure.",
                              "lineHeight": 1.6,
                              "fontFamily": "Inter",
                              "fontSize": 14,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "text",
                              "id": "D1RfS",
                              "name": "li4",
                              "fill": "#785E48",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "4.  Background optimization (experimental, disabled by default) — execution/optimizer.py queues a job after fit or evaluate. Spawns a detached worker process, scores candidate policies against baseline using black-box evaluation, promotes winning candidates (manual or auto mode).",
                              "lineHeight": 1.6,
                              "fontFamily": "Inter",
                              "fontSize": 14,
                              "fontWeight": "normal"
                            }
                          ]
                        }
                      ]
                    },
                    {
                      "type": "frame",
                      "id": "qOen2",
                      "name": "sectionStateMachine",
                      "width": "fill_container",
                      "layout": "vertical",
                      "gap": 12,
                      "children": [
                        {
                          "type": "text",
                          "id": "OlB78",
                          "name": "h2tsm",
                          "fill": "#2D1F14",
                          "content": "Task State Machine",
                          "fontFamily": "Space Grotesk",
                          "fontSize": 23,
                          "fontWeight": "600"
                        },
                        {
                          "type": "text",
                          "id": "fdO7L",
                          "name": "ptsm",
                          "fill": "#785E48",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "Each task in the checkpoint progresses through these states:",
                          "lineHeight": 1.6,
                          "fontFamily": "Inter",
                          "fontSize": 14,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "frame",
                          "id": "vaixa",
                          "name": "statesFlow",
                          "width": "fill_container",
                          "fill": "#231A12",
                          "cornerRadius": 10,
                          "padding": [
                            16,
                            20
                          ],
                          "children": [
                            {
                              "type": "text",
                              "id": "WpMjt",
                              "name": "statesText",
                              "fill": "#e8e6e3",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "pending → train_suite_generated → train_suite_approved → adversarially_reviewed → complete",
                              "lineHeight": 1.5,
                              "fontFamily": "JetBrains Mono",
                              "fontSize": 12.5,
                              "fontWeight": "normal"
                            }
                          ]
                        },
                        {
                          "type": "text",
                          "id": "nMnAW",
                          "name": "resumeNote",
                          "fill": "#785E48",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "The fit loop resumes from the last incomplete state on restart.",
                          "lineHeight": 1.6,
                          "fontFamily": "Inter",
                          "fontSize": 14,
                          "fontWeight": "normal"
                        }
                      ]
                    },
                    {
                      "type": "frame",
                      "id": "MoFLR",
                      "name": "sectionModuleRoles",
                      "width": "fill_container",
                      "layout": "vertical",
                      "gap": 12,
                      "children": [
                        {
                          "type": "text",
                          "id": "YdNqT",
                          "name": "h2mr",
                          "fill": "#2D1F14",
                          "content": "Module Roles",
                          "fontFamily": "Space Grotesk",
                          "fontSize": 23,
                          "fontWeight": "600"
                        },
                        {
                          "type": "frame",
                          "id": "8g52L",
                          "name": "moduleTable",
                          "clip": true,
                          "width": "fill_container",
                          "cornerRadius": 8,
                          "stroke": {
                            "thickness": 1,
