                              "fontSize": 18,
                              "fontWeight": "600"
                            }
                          ]
                        },
                        {
                          "type": "frame",
                          "id": "x9hc2",
                          "name": "subDockerNotAvail",
                          "width": "fill_container",
                          "layout": "vertical",
                          "gap": 8,
                          "children": [
                            {
                              "type": "text",
                              "id": "1jRSB",
                              "name": "sub5h3",
                              "fill": "#2D1F14",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "Docker not available",
                              "fontFamily": "Space Grotesk",
                              "fontSize": 18,
                              "fontWeight": "600"
                            },
                            {
                              "type": "frame",
                              "id": "wRAZd",
                              "name": "codeBlock9",
                              "width": "fill_container",
                              "fill": "#231A12",
                              "cornerRadius": 8,
                              "padding": [
                                8,
                                12
                              ],
                              "children": [
                                {
                                  "type": "text",
                                  "id": "2dI0E",
                                  "name": "sub5codeText",
                                  "fill": "#e8e6e3",
                                  "textGrowth": "fixed-width",
                                  "width": "fill_container",
                                  "content": "Sandbox: Docker unavailable, falling back to host pytest",
                                  "lineHeight": 1.5,
                                  "fontFamily": "JetBrains Mono",
                                  "fontSize": 11,
                                  "fontWeight": "normal"
                                }
                              ]
                            },
                            {
                              "type": "text",
                              "id": "2rOk3",
                              "name": "sub5p",
                              "fill": "#785E48",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "When running crucis run, Crucis checks for Docker availability via docker info. If Docker is not installed or the daemon is not running, Crucis falls back to running pytest directly on the host.\n\nTo use the Docker sandbox:\n1. Install Docker\n2. Start the Docker daemon\n3. Run without the --no-sandbox flag\n\nTo explicitly skip Docker:\ncrucis run --no-sandbox",
                              "lineHeight": 1.6,
                              "fontFamily": "Inter",
                              "fontSize": 14,
                              "fontWeight": "normal"
                            }
                          ]
                        },
                        {
                          "type": "frame",
                          "id": "C7BQe",
                          "name": "subHostPytest",
                          "width": "fill_container",
                          "layout": "vertical",
                          "gap": 8,
                          "children": [
                            {
                              "type": "text",
                              "id": "4wxDh",
                              "name": "sub6h3",
                              "fill": "#2D1F14",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "Host pytest missing",
                              "fontFamily": "Space Grotesk",
                              "fontSize": 18,
                              "fontWeight": "600"
                            },
                            {
                              "type": "text",
                              "id": "0IQSH",
                              "name": "sub6p",
                              "fill": "#785E48",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "When Docker is unavailable (or --no-sandbox is used), Crucis runs host verification via python -m pytest. If pytest is missing, Crucis now fails fast with a preflight error.\n\nFix by installing pytest into the active environment:",
                              "lineHeight": 1.6,
                              "fontFamily": "Inter",
                              "fontSize": 14,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "frame",
                              "id": "E17uQ",
                              "name": "codeBlock10",
                              "width": "fill_container",
                              "fill": "#231A12",
                              "cornerRadius": 8,
                              "padding": [
                                8,
                                12
                              ],
                              "children": [
                                {
                                  "type": "text",
                                  "id": "tETX6",
                                  "name": "sub6fixText",
                                  "fill": "#e8e6e3",
                                  "textGrowth": "fixed-width",
                                  "width": "fill_container",
                                  "content": "uv pip install pytest   # or: pip install pytest",
                                  "lineHeight": 1.5,
                                  "fontFamily": "JetBrains Mono",
                                  "fontSize": 11,
                                  "fontWeight": "normal"
                                }
                              ]
                            }
                          ]
                        }
                      ]
                    },
                    {
                      "type": "frame",
