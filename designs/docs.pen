                              "width": "fill_container",
                              "content": "Python 3.10+ is supported. Python 3.12+ is recommended for the best experience. Versions below 3.10 are rejected at runtime. Run crucis doctor to check your version.",
                              "lineHeight": 1.6,
                              "fontFamily": "Inter",
                              "fontSize": 14,
                              "fontWeight": "normal"
                            }
                          ]
                        },
                        {
                          "type": "frame",
                          "id": "lKas6",
                          "name": "q4",
                          "width": "fill_container",
                          "layout": "vertical",
                          "gap": 12,
                          "children": [
                            {
                              "type": "text",
                              "id": "b3Kbn",
                              "name": "q4h",
                              "fill": "#2D1F14",
                              "content": "Do I need Docker?",
                              "fontFamily": "Space Grotesk",
                              "fontSize": 23,
                              "fontWeight": "600"
                            },
                            {
                              "type": "text",
                              "id": "DIq6r",
                              "name": "q4a",
                              "fill": "#785E48",
                              "content": "No. Docker is optional. When Docker is unavailable, Crucis runs pytest directly on the host. Use --no-sandbox to explicitly skip Docker. See Troubleshooting.",
                              "lineHeight": 1.6,
                              "fontFamily": "Inter",
                              "fontSize": 14,
                              "fontWeight": "normal"
                            }
                          ]
                        },
                        {
                          "type": "frame",
                          "id": "Vmf5A",
                          "name": "q6",
                          "width": "fill_container",
                          "layout": "vertical",
                          "gap": 12,
                          "children": [
                            {
                              "type": "text",
                              "id": "9wWye",
                              "name": "q6h",
                              "fill": "#2D1F14",
                              "content": "How do I use Crucis with an existing codebase?",
                              "fontFamily": "Space Grotesk",
                              "fontSize": 23,
                              "fontWeight": "600"
                            },
                            {
                              "type": "text",
                              "id": "L1qNv",
                              "name": "q6a",
                              "fill": "#785E48",
                              "content": "Use crucis init --existing-codebase and set target_files, context_files, and existing_tests in your objective. See Existing Codebase Quickstart.",
                              "lineHeight": 1.6,
                              "fontFamily": "Inter",
                              "fontSize": 14,
                              "fontWeight": "normal"
                            }
                          ]
                        },
                        {
                          "type": "frame",
                          "id": "D1Wgs",
                          "name": "qCost",
                          "width": "fill_container",
                          "layout": "vertical",
                          "gap": 12,
                          "children": [
                            {
                              "type": "text",
                              "id": "tXKPX",
                              "name": "costQ",
                              "fill": "#2D1F14",
                              "content": "How much does it cost?",
                              "fontFamily": "Space Grotesk",
                              "fontSize": 16,
                              "fontWeight": "600"
                            },
                            {
                              "type": "text",
                              "id": "8gTQM",
                              "name": "costA",
                              "fill": "#785E48",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "Crucis itself is free and open source. The only cost is API calls to your chosen LLM provider. A typical run uses 2-5 API calls per task for test generation and 1-3 for implementation.",
                              "lineHeight": 1.6,
                              "fontFamily": "Inter",
                              "fontSize": 14,
                              "fontWeight": "normal"
                            }
                          ]
                        }
                      ]
                    },
                    {
                      "type": "frame",
                      "id": "oSWVD",
                      "name": "sectionHowItWorks",
                      "width": "fill_container",
                      "layout": "vertical",
                      "gap": 16,
                      "children": [
                        {
                          "type": "frame",
                          "id": "aMlpG",
                          "name": "h2Wrapper",
                          "width": "fill_container",
                          "gap": 8,
                          "alignItems": "center",
                          "children": [
                            {
                              "type": "icon_font",
                              "id": "yFk09",
                              "name": "sec2icon",
                              "width": 20,
                              "height": 20,
                              "iconFontName": "git-branch",
                              "iconFontFamily": "lucide",
                              "fill": "#785E48"
                            },
                            {
                              "type": "text",
                              "id": "KtGWg",
                              "name": "sec2h2",
                              "fill": "#2D1F14",
                              "content": "How It Works",
                              "fontFamily": "Space Grotesk",
                              "fontSize": 23,
                              "fontWeight": "600"
                            }
                          ]
                        },
                        {
                          "type": "frame",
                          "id": "IeAeS",
                          "name": "q3",
                          "width": "fill_container",
                          "layout": "vertical",
                          "gap": 12,
                          "children": [
                            {
                              "type": "text",
                              "id": "BsKii",
                              "name": "q3h",
                              "fill": "#2D1F14",
                              "content": "What happens if fit is interrupted?",
                              "fontFamily": "Space Grotesk",
                              "fontSize": 23,
                              "fontWeight": "600"
                            },
                            {
                              "type": "text",
                              "id": "uhwu1",
                              "name": "q3a",
                              "fill": "#785E48",
                              "content": "Crucis saves the checkpoint after each task completes. Re-run the same command and it resumes from the last completed task. No work is lost.",
                              "lineHeight": 1.6,
                              "fontFamily": "Inter",
                              "fontSize": 14,
                              "fontWeight": "normal"
                            }
                          ]
                        },
                        {
                          "type": "frame",
                          "id": "SOHot",
                          "name": "q5",
                          "width": "fill_container",
                          "layout": "vertical",
                          "gap": 12,
                          "children": [
                            {
                              "type": "text",
                              "id": "St2QX",
                              "name": "q5h",
                              "fill": "#2D1F14",
                              "content": "What are holdout evals?",
                              "fontFamily": "Space Grotesk",
                              "fontSize": 23,
                              "fontWeight": "600"
                            },
                            {
                              "type": "text",
                              "id": "1Z98G",
                              "name": "q5a",
                              "fill": "#785E48",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "Hidden input/output pairs that are never shown to any agent. After the implementation agent writes code, Crucis runs these pairs as a final safety net to verify the implementation generalizes beyond the training examples.\n\nYou don't need to write them manually. Just list all your examples under examples: and Crucis automatically reserves the last ~20% as holdout evals (auto-holdout). You can still provide an explicit holdout: section if you prefer full control. See Objective Format Reference.",
                              "lineHeight": 1.6,
                              "fontFamily": "Inter",
                              "fontSize": 14,
                              "fontWeight": "normal"
                            }
                          ]
                        },
                        {
                          "type": "frame",
                          "id": "HYzyK",
                          "name": "q7",
                          "width": "fill_container",
                          "layout": "vertical",
                          "gap": 12,
                          "children": [
                            {
                              "type": "text",
                              "id": "KDws7",
                              "name": "q7h",
                              "fill": "#2D1F14",
                              "content": "What does the optimizer do?",
                              "fontFamily": "Space Grotesk",
                              "fontSize": 23,
                              "fontWeight": "600"
                            },
                            {
                              "type": "text",
                              "id": "LD2JH",
                              "name": "q7a",
                              "fill": "#785E48",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "The background optimizer (GEPA) learns better prompt strategies over time by analyzing generation outcomes across runs. It's experimental and disabled by default. To enable it, set optimizer.enabled: true in .crucis/settings.yaml. See Background Optimizer.",
                              "lineHeight": 1.6,
                              "fontFamily": "Inter",
                              "fontSize": 14,
                              "fontWeight": "normal"
                            }
                          ]
                        }
                      ]
                    },
                    {
                      "type": "frame",
                      "id": "30qtl",
                      "name": "sectionConfigCustom",
                      "width": "fill_container",
                      "layout": "vertical",
                      "gap": 16,
                      "children": [
                        {
                          "type": "frame",
                          "id": "SqqJf",
                          "name": "h2Wrapper",
                          "width": "fill_container",
                          "gap": 8,
                          "alignItems": "center",
                          "children": [
                            {
                              "type": "icon_font",
                              "id": "kVSBP",
                              "name": "sec3icon",
                              "width": 20,
                              "height": 20,
                              "iconFontName": "settings",
                              "iconFontFamily": "lucide",
                              "fill": "#785E48"
                            },
                            {
                              "type": "text",
                              "id": "1EDB6",
                              "name": "sec3h2",
                              "fill": "#2D1F14",
                              "content": "Configuration & Customization",
                              "fontFamily": "Space Grotesk",
                              "fontSize": 23,
                              "fontWeight": "600"
                            }
                          ]
                        },
                        {
                          "type": "frame",
                          "id": "SGlJH",
                          "name": "q2",
                          "width": "fill_container",
                          "layout": "vertical",
                          "gap": 12,
                          "children": [
                            {
                              "type": "text",
                              "id": "J64xS",
                              "name": "q2h",
                              "fill": "#2D1F14",
                              "content": "How do I switch between Claude and Codex?",
                              "fontFamily": "Space Grotesk",
                              "fontSize": 23,
                              "fontWeight": "600"
                            },
                            {
                              "type": "text",
                              "id": "pg43k",
                              "name": "q2a",
                              "fill": "#785E48",
                              "content": "Edit .crucis/settings.yaml:",
                              "lineHeight": 1.6,
                              "fontFamily": "Inter",
                              "fontSize": 14,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "frame",
                              "id": "SYkLy",
                              "name": "codeBlock",
                              "width": "fill_container",
                              "fill": "#231A12",
                              "cornerRadius": 10,
                              "padding": [
                                16,
                                20
                              ],
                              "children": [
                                {
                                  "type": "text",
                                  "id": "JZ5V2",
                                  "name": "q2codeText",
                                  "fill": "#e8e6e3",
                                  "textGrowth": "fixed-width",
                                  "width": "fill_container",
                                  "content": "agents:\n  generation_agent: codex   # or &quot;claude&quot;\n  generation_model: null     # null = agent default",
                                  "lineHeight": 1.5,
                                  "fontFamily": "JetBrains Mono",
                                  "fontSize": 12.5,
                                  "fontWeight": "normal"
                                }
                              ]
                            },
                            {
                              "type": "text",
                              "id": "5StIT",
                              "name": "q2b",
                              "fill": "#785E48",
                              "content": "Or set environment variables: GENERATION_AGENT=codex. See Configuration for all agent settings.",
                              "lineHeight": 1.6,
                              "fontFamily": "Inter",
                              "fontSize": 14,
                              "fontWeight": "normal"
                            }
                          ]
                        },
                        {
                          "type": "frame",
                          "id": "hHfDp",
                          "name": "q8",
                          "width": "fill_container",
                          "layout": "vertical",
                          "gap": 12,
                          "children": [
                            {
                              "type": "text",
                              "id": "eVN7h",
                              "name": "q8h",
                              "fill": "#2D1F14",
                              "content": "Can I use Crucis from Claude Code / OpenCode / Codex?",
                              "fontFamily": "Space Grotesk",
                              "fontSize": 23,
                              "fontWeight": "600"
                            },
                            {
                              "type": "text",
                              "id": "7rhH1",
                              "name": "q8a",
                              "fill": "#785E48",
                              "content": "Yes. Crucis ships an MCP server (crucis-mcp) that exposes every CLI command as a tool your agent can call. Add it to your MCP config and authorize the workspace:",
                              "lineHeight": 1.6,
                              "fontFamily": "Inter",
                              "fontSize": 14,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "frame",
                              "id": "ItR26",
                              "name": "codeBlock",
                              "width": "fill_container",
                              "fill": "#231A12",
                              "cornerRadius": 10,
                              "padding": [
                                16,
                                20
                              ],
                              "children": [
                                {
                                  "type": "text",
                                  "id": "6KPtS",
                                  "name": "q8codeText",
                                  "fill": "#e8e6e3",
                                  "content": "mkdir -p .crucis && touch .crucis/mcp_enabled",
                                  "lineHeight": 1.5,
                                  "fontFamily": "JetBrains Mono",
                                  "fontSize": 12.5,
                                  "fontWeight": "normal"
                                }
                              ]
                            },
                            {
                              "type": "text",
                              "id": "rhkEM",
                              "name": "q8b",
                              "fill": "#785E48",
                              "content": "See MCP Server for setup, tool reference, and the step-by-step agent workflow.",
                              "lineHeight": 1.6,
                              "fontFamily": "Inter",
                              "fontSize": 14,
                              "fontWeight": "normal"
                            }
                          ]
                        },
                        {
                          "type": "frame",
                          "id": "Q5C7t",
                          "name": "q9",
                          "width": "fill_container",
                          "layout": "vertical",
                          "gap": 12,
                          "children": [
                            {
                              "type": "text",
                              "id": "egeXE",
                              "name": "q9h",
                              "fill": "#2D1F14",
                              "content": "How do I reset a failed checkpoint?",
                              "fontFamily": "Space Grotesk",
                              "fontSize": 23,
                              "fontWeight": "600"
                            },
                            {
                              "type": "frame",
                              "id": "6PkjH",
                              "name": "codeBlock",
                              "width": "fill_container",
                              "fill": "#231A12",
                              "cornerRadius": 10,
                              "padding": [
                                16,
                                20
                              ],
                              "children": [
                                {
                                  "type": "text",
                                  "id": "eQYXS",
                                  "name": "q9codeText",
                                  "fill": "#e8e6e3",
                                  "textGrowth": "fixed-width",
                                  "width": "fill_container",
                                  "content": "# Reset everything (prompts for confirmation)\ncrucis run --reset\n\n# Skip the confirmation prompt\ncrucis run --reset -y\n\n# Reset only specific tasks\ncrucis run --reset-task my_task",
                                  "lineHeight": 1.5,
                                  "fontFamily": "JetBrains Mono",
                                  "fontSize": 12.5,
                                  "fontWeight": "normal"
                                }
                              ]
                            },
                            {
                              "type": "text",
                              "id": "8QzS1",
                              "name": "q9a",
                              "fill": "#785E48",
                              "content": "See CLI Reference for details.",
                              "lineHeight": 1.6,
                              "fontFamily": "Inter",
                              "fontSize": 14,
                              "fontWeight": "normal"
                            }
                          ]
                        },
                        {
                          "type": "frame",
                          "id": "qaaqF",
                          "name": "q10",
                          "width": "fill_container",
                          "layout": "vertical",
                          "gap": 12,
                          "children": [
                            {
                              "type": "text",
                              "id": "2r1lQ",
                              "name": "q10h",
                              "fill": "#2D1F14",
                              "content": "How do I increase the agent timeout?",
                              "fontFamily": "Space Grotesk",
                              "fontSize": 23,
                              "fontWeight": "600"
                            },
                            {
                              "type": "text",
                              "id": "V5DoB",
                              "name": "q10a",
                              "fill": "#785E48",
                              "content": "The default agent timeout is 300 seconds. For complex objectives or slow models, pass --timeout:",
                              "lineHeight": 1.6,
                              "fontFamily": "Inter",
                              "fontSize": 14,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "frame",
                              "id": "KfQzR",
                              "name": "codeBlock",
                              "width": "fill_container",
                              "fill": "#231A12",
                              "cornerRadius": 10,
                              "padding": [
                                16,
                                20
                              ],
                              "children": [
                                {
                                  "type": "text",
                                  "id": "AwD7g",
                                  "name": "q10codeText",
                                  "fill": "#e8e6e3",
                                  "textGrowth": "fixed-width",
                                  "width": "fill_container",
                                  "content": "crucis run --timeout 600   # 10 minutes",
                                  "lineHeight": 1.5,
                                  "fontFamily": "JetBrains Mono",
                                  "fontSize": 12.5,
                                  "fontWeight": "normal"
                                }
                              ]
                            }
                          ]
                        },
                        {
                          "type": "frame",
                          "id": "vfI5K",
                          "name": "q11",
                          "width": "fill_container",
                          "layout": "vertical",
                          "gap": 12,
                          "children": [
                            {
                              "type": "text",
                              "id": "U0egE",
                              "name": "q11h",
                              "fill": "#2D1F14",
                              "content": "Do I need to write constraint profiles?",
                              "fontFamily": "Space Grotesk",
                              "fontSize": 23,
                              "fontWeight": "600"
                            },
                            {
                              "type": "text",
                              "id": "DYr6p",
                              "name": "q11a",
                              "fill": "#785E48",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "No. Built-in defaults (default and recommended) are used when no constraints/profiles.yaml exists. You only need a custom profiles file if you want to adjust constraint thresholds. Constraints use a flat list format and are auto-classified as \"required\" (blocking) or \"advisory\" (non-blocking).",
                              "lineHeight": 1.6,
                              "fontFamily": "Inter",
                              "fontSize": 14,
                              "fontWeight": "normal"
                            }
                          ]
                        },
                        {
                          "type": "frame",
                          "id": "Diqgx",
                          "name": "q13",
                          "width": "fill_container",
                          "layout": "vertical",
                          "gap": 12,
                          "children": [
                            {
                              "type": "text",
                              "id": "7krDD",
                              "name": "q13h",
                              "fill": "#2D1F14",
                              "content": "How do I validate my objective?",
                              "fontFamily": "Space Grotesk",
                              "fontSize": 23,
                              "fontWeight": "600"
                            },
                            {
                              "type": "frame",
                              "id": "vDUd1",
                              "name": "codeBlock",
                              "width": "fill_container",
                              "fill": "#231A12",
                              "cornerRadius": 10,
                              "padding": [
                                16,
                                20
                              ],
                              "children": [
                                {
                                  "type": "text",
                                  "id": "vfrJP",
                                  "name": "q13codeText1",
                                  "fill": "#e8e6e3",
                                  "textGrowth": "fixed-width",
                                  "width": "fill_container",
                                  "content": "crucis validate objective.yaml",
                                  "lineHeight": 1.5,
                                  "fontFamily": "JetBrains Mono",
                                  "fontSize": 12.5,
                                  "fontWeight": "normal"
                                }
                              ]
                            },
                            {
                              "type": "text",
                              "id": "98DHa",
                              "name": "q13a",
                              "fill": "#785E48",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "By default this runs structural checks and an LLM semantic review that verifies each eval's expected output against the described behavior. The agent streams its progress in real time.\n\nTo skip the LLM review and only run fast structural checks:",
                              "lineHeight": 1.6,
                              "fontFamily": "Inter",
                              "fontSize": 14,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "frame",
                              "id": "rLRXt",
                              "name": "codeBlock2",
                              "width": "fill_container",
                              "fill": "#231A12",
                              "cornerRadius": 10,
                              "padding": [
                                16,
                                20
                              ],
                              "children": [
                                {
                                  "type": "text",
                                  "id": "oNEqM",
                                  "name": "q13codeText2",
                                  "fill": "#e8e6e3",
                                  "textGrowth": "fixed-width",
                                  "width": "fill_container",
                                  "content": "crucis validate objective.yaml --static",
                                  "lineHeight": 1.5,
                                  "fontFamily": "JetBrains Mono",
                                  "fontSize": 12.5,
                                  "fontWeight": "normal"
                                }
                              ]
                            }
                          ]
                        },
                        {
                          "type": "frame",
                          "id": "yVLnn",
                          "name": "qCiCd",
                          "width": "fill_container",
                          "layout": "vertical",
                          "gap": 12,
                          "children": [
                            {
                              "type": "text",
                              "id": "ylfZR",
                              "name": "cicdQ",
                              "fill": "#2D1F14",
                              "content": "Can I use Crucis in CI/CD?",
                              "fontFamily": "Space Grotesk",
                              "fontSize": 16,
                              "fontWeight": "600"
                            },
                            {
                              "type": "text",
                              "id": "nGyJt",
                              "name": "cicdA",
                              "fill": "#785E48",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "Yes. Use crucis run --no-sandbox in your CI pipeline. The CLI exits with code 0 on success and non-zero on failure, making it straightforward to integrate with GitHub Actions, GitLab CI, or any CI system.",
                              "lineHeight": 1.6,
                              "fontFamily": "Inter",
                              "fontSize": 14,
                              "fontWeight": "normal"
                            }
                          ]
                        }
                      ]
                    },
                    {
                      "type": "frame",
                      "id": "xlpW3",
                      "name": "sectionTroubleshooting",
                      "width": "fill_container",
                      "layout": "vertical",
                      "gap": 16,
                      "children": [
                        {
                          "type": "frame",
                          "id": "T4kjd",
                          "name": "h2Wrapper",
                          "width": "fill_container",
                          "gap": 8,
                          "alignItems": "center",
                          "children": [
                            {
                              "type": "icon_font",
                              "id": "xSeUb",
                              "name": "sec4icon",
                              "width": 20,
                              "height": 20,
                              "iconFontName": "wrench",
                              "iconFontFamily": "lucide",
                              "fill": "#785E48"
                            },
                            {
                              "type": "text",
                              "id": "5L7Uj",
                              "name": "sec4h2",
                              "fill": "#2D1F14",
                              "content": "Troubleshooting",
                              "fontFamily": "Space Grotesk",
                              "fontSize": 23,
                              "fontWeight": "600"
                            }
                          ]
                        },
                        {
                          "type": "frame",
                          "id": "MA4ld",
                          "name": "q12",
                          "width": "fill_container",
                          "layout": "vertical",
                          "gap": 12,
                          "children": [
                            {
                              "type": "text",
                              "id": "208I5",
                              "name": "q12h",
                              "fill": "#2D1F14",
                              "content": "Does Codex require a git repository?",
                              "fontFamily": "Space Grotesk",
                              "fontSize": 23,
                              "fontWeight": "600"
                            },
                            {
                              "type": "text",
                              "id": "jSPW7",
                              "name": "q12a",
                              "fill": "#785E48",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "Yes. Codex requires a trusted git directory. Run git init && git add -A && git commit -m \"init\" before using Codex. Crucis prints a hint about this after crucis init when no .git directory exists.",
                              "lineHeight": 1.6,
                              "fontFamily": "Inter",
                              "fontSize": 14,
                              "fontWeight": "normal"
                            }
                          ]
                        }
