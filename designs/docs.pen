                    },
                    {
                      "type": "text",
                      "id": "rlBQI",
                      "name": "h2_sec",
                      "fill": "#2D1F14",
                      "content": "Security",
                      "fontFamily": "Space Grotesk",
                      "fontSize": 23,
                      "fontWeight": "600"
                    },
                    {
                      "type": "text",
                      "id": "2mEpg",
                      "name": "p_auth",
                      "fill": "#785E48",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "Workspace authorization — Every tool call verifies the workspace is authorized before proceeding. A workspace must opt in via a marker file (.crucis/mcp_enabled) or the environment variable CRUCIS_MCP_AUTHORIZED=1. Unauthorized workspaces receive a WorkspaceNotAuthorizedError.",
                      "lineHeight": 1.6,
                      "fontFamily": "Inter",
                      "fontSize": 14,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "9gJVs",
                      "name": "p_path",
                      "fill": "#785E48",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "Path traversal prevention — All file path arguments are resolved (including symlinks) and checked against the workspace boundary. Null bytes in paths are rejected. Paths exceeding 4,096 characters are rejected. Any resolved path outside the workspace is blocked with a PathTraversalError.",
                      "lineHeight": 1.6,
                      "fontFamily": "Inter",
                      "fontSize": 14,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "DnJmd",
                      "name": "p_input",
                      "fill": "#785E48",
                      "content": "Input size limits — Source code inputs (for crucis_check_constraints and crucis_submit_test_suite) are limited to 1 MB to prevent resource exhaustion.",
                      "lineHeight": 1.6,
                      "fontFamily": "Inter",
                      "fontSize": 14,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "CfkJP",
                      "name": "p_cred",
                      "fill": "#785E48",
                      "content": "Credential handling — API keys and secrets are read from environment variables, never from tool parameters. The server itself stores no credentials.",
                      "lineHeight": 1.6,
                      "fontFamily": "Inter",
                      "fontSize": 14,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "Ktbp1",
                      "name": "p_stdio",
                      "fill": "#785E48",
                      "content": "STDIO isolation — The server redirects Rich console output to stderr to prevent UI text from corrupting the JSON-RPC protocol on stdout.",
                      "lineHeight": 1.6,
                      "fontFamily": "Inter",
                      "fontSize": 14,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "ilCi5",
                      "name": "h2_prompts",
                      "fill": "#2D1F14",
