                          "type": "text",
                          "id": "jEBzE",
                          "fill": "#e8e6e3",
                          "content": "name: add\ndescription: Add two integers.\nsignature: \"add(a: int, b: int) -> int\"\ntarget_files:\n  - \"src/solution.py\"\ntrain_evals:\n  - input: \"(1, 2)\"\n    output: \"3\"\nholdout_evals:\n  - input: \"(100, 23)\"\n    output: \"123\"",
                          "lineHeight": 1.5,
                          "fontFamily": "JetBrains Mono",
                          "fontSize": 11,
                          "fontWeight": "normal"
                        }
                      ]
                    },
