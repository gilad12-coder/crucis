                        {
                          "type": "frame",
                          "id": "q83SO",
                          "name": "subAgentBinary",
                          "width": "fill_container",
                          "layout": "vertical",
                          "gap": 8,
                          "children": [
                            {
                              "type": "text",
                              "id": "oa5f0",
                              "name": "sub3h3",
                              "fill": "#2D1F14",
