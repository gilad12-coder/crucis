                          "fill": "#785E48",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "By default, crucis init creates only two files: objective.yaml and src/solution.py. Profiles and settings are optional — add them with --with-profiles or --with-settings. Settings are auto-created on first crucis run if they don't exist.",
                          "lineHeight": 1.6,
                          "fontFamily": "Inter",
                          "fontSize": 14,
                          "fontWeight": "normal"
                        },
