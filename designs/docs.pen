                      ]
                    },
                    {
                      "type": "text",
                      "id": "MZM0j",
                      "name": "intro1",
                      "fill": "#785E48",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "Crucis ships an MCP (Model Context Protocol) server that exposes its autonomy scaffold as tools, resources, and prompts. AI agents running inside Claude Code, OpenCode, Codex, or any MCP-compatible host can use Crucis natively without shelling out to the CLI.",
                      "lineHeight": 1.6,
                      "fontFamily": "Inter",
                      "fontSize": 14,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "h3N4f",
                      "name": "h2_modes",
                      "fill": "#2D1F14",
                      "content": "Two modes of operation",
                      "fontFamily": "Space Grotesk",
                      "fontSize": 23,
                      "fontWeight": "600"
                    },
                    {
                      "type": "text",
                      "id": "lHjkY",
                      "name": "p_pipe",
                      "fill": "#785E48",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "Pipeline mode — Crucis spawns its own subprocess agents (Claude, Codex) to handle generation, adversarial review, and implementation. You call a single tool like crucis_run and get results when done. Best for: automated workflows, CI-style runs, hands-off execution.",
                      "lineHeight": 1.6,
                      "fontFamily": "Inter",
                      "fontSize": 14,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "mnbPf",
                      "name": "p_step",
                      "fill": "#785E48",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "Step-by-step mode — Your agent acts as the generator, critic, and implementer. Crucis provides the prompts, validates your work, and verifies correctness. Best for: interactive development, learning the TDD flow, fine-grained control.",
                      "lineHeight": 1.6,
                      "fontFamily": "Inter",
                      "fontSize": 14,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "xR3IV",
                      "name": "h2_qs",
                      "fill": "#2D1F14",
                      "content": "Quick start",
                      "fontFamily": "Space Grotesk",
                      "fontSize": 23,
                      "fontWeight": "600"
                    },
                    {
                      "type": "frame",
                      "id": "1fBCL",
                      "name": "code_qs",
                      "width": "fill_container",
                      "fill": "#231A12",
                      "cornerRadius": 10,
                      "padding": [
                        16,
                        20
                      ],
                      "children": [
                        {
                          "type": "text",
                          "id": "rv95B",
                          "fill": "#e8e6e3",
                          "content": "# 1. Authorize the workspace\nmkdir -p .crucis && touch .crucis/mcp_enabled\n# or: export CRUCIS_MCP_AUTHORIZED=1\n\n# 2. Configure your MCP host\n# .mcp.json\n{\n  \"mcpServers\": {\n    \"crucis\": {\n      \"command\": \"crucis-mcp\",\n      \"env\": {\n        \"CRUCIS_WORKSPACE\": \"/path/to/your/project\",\n        \"CRUCIS_MCP_AUTHORIZED\": \"1\"\n      }\n    }\n  }\n}\n\n# 3. Use the tools (19 available)\ncrucis_validate → crucis_doctor → crucis_run → crucis_summary",
                          "lineHeight": 1.5,
                          "fontFamily": "JetBrains Mono",
                          "fontSize": 12.5,
                          "fontWeight": "normal"
                        }
                      ]
                    },
