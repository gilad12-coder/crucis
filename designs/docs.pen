                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "If you're starting fresh, initialize a workspace first:",
                              "lineHeight": 1.6,
                              "fontFamily": "Inter",
                              "fontSize": 14,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "frame",
                              "id": "Up7Qo",
                              "name": "codeBlock2",
                              "width": "fill_container",
                              "fill": "#231A12",
                              "cornerRadius": 10,
                              "padding": [
                                16,
                                20
                              ],
                              "children": [
                                {
                                  "type": "text",
                                  "id": "KkBva",
                                  "name": "sub1fixText",
                                  "fill": "#e8e6e3",
                                  "content": "crucis init --name my_function",
                                  "lineHeight": 1.5,
                                  "fontFamily": "JetBrains Mono",
