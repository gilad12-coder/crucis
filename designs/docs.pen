                              "fontWeight": "normal"
                            }
                          ]
                        }
                      ]
                    },
                    {
                      "type": "text",
                      "id": "D3qEj",
                      "name": "mdNote",
                      "fill": "#785E48",
                      "content": "Run crucis doctor to detect agent/model mismatches (e.g. a Claude agent configured with a GPT model).",
                      "lineHeight": 1.6,
                      "fontFamily": "Inter",
                      "fontSize": 14,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "cFkV4",
                      "name": "h2cp",
                      "fill": "#2D1F14",
                      "content": "Constraint Profiles",
                      "fontFamily": "Space Grotesk",
                      "fontSize": 23,
                      "fontWeight": "600"
                    },
                    {
                      "type": "text",
                      "id": "U0rNC",
                      "name": "cptext",
                      "fill": "#785E48",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "Constraint profiles are loaded from constraints/profiles.yaml (or a custom file via --profiles). Each profile lists constraints flat — they are auto-classified into required (blocking) or advisory based on the field type. The old nested primary:/secondary: format still works for backward compatibility. See the Constraints Reference for all 44 available constraints and the list of advisory fields.",
                      "lineHeight": 1.6,
                      "fontFamily": "Inter",
                      "fontSize": 14,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "rHVpr",
                      "name": "h2co",
                      "fill": "#2D1F14",
                      "content": "Color and Output",
                      "fontFamily": "Space Grotesk",
                      "fontSize": 23,
                      "fontWeight": "600"
                    },
                    {
                      "type": "text",
                      "id": "5o5cK",
                      "name": "coIntro",
                      "fill": "#785E48",
                      "content": "Crucis routes all UI output (Rich-formatted messages, tables, spinners) to stderr and data output (JSON from --json flags) to stdout. This lets you pipe JSON output cleanly:",
                      "lineHeight": 1.6,
                      "fontFamily": "Inter",
                      "fontSize": 14,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "frame",
                      "id": "LB7AG",
                      "name": "cb3",
                      "width": "fill_container",
                      "fill": "#231A12",
                      "cornerRadius": 10,
                      "padding": [
                        16,
                        20
                      ],
                      "children": [
                        {
                          "type": "text",
                          "id": "D3pBM",
                          "fill": "#e8e6e3",
                          "content": "crucis status --json | jq '.task_progress'",
                          "lineHeight": 1.5,
                          "fontFamily": "JetBrains Mono",
                          "fontSize": 12.5,
                          "fontWeight": "normal"
                        }
                      ]
                    },
                    {
                      "type": "text",
                      "id": "GAdvh",
                      "name": "coColor",
                      "fill": "#785E48",
                      "content": "Color is enabled by default when stderr is a TTY. Override with:",
                      "lineHeight": 1.6,
                      "fontFamily": "Inter",
                      "fontSize": 14,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "BbBpv",
                      "name": "coFlags",
                      "fill": "#785E48",
                      "content": "• --color / --no-color flags (see CLI Reference)\n• NO_COLOR environment variable (see no-color.org)",
                      "lineHeight": 1.6,
                      "fontFamily": "Inter",
                      "fontSize": 14,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "MGnLO",
                      "name": "coPrecedence",
                      "fill": "#785E48",
                      "content": "--color takes precedence over NO_COLOR when both are set.",
                      "lineHeight": 1.6,
                      "fontFamily": "Inter",
                      "fontSize": 14,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "fsbkN",
                      "name": "h2mcp",
                      "fill": "#2D1F14",
                      "content": "MCP Server",
                      "fontFamily": "Space Grotesk",
                      "fontSize": 23,
                      "fontWeight": "600"
                    },
                    {
                      "type": "text",
                      "id": "7vtiW",
                      "name": "mcpIntro",
                      "fill": "#785E48",
                      "content": "When running Crucis as an MCP server, these additional environment variables apply:",
                      "lineHeight": 1.6,
                      "fontFamily": "Inter",
                      "fontSize": 14,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "frame",
                      "id": "X1fAK",
                      "name": "tblmcp",
                      "width": "fill_container",
                      "cornerRadius": 8,
                      "stroke": {
                        "thickness": 1,
                        "fill": "#D4C4AD"
                      },
                      "layout": "vertical",
                      "children": [
                        {
                          "type": "frame",
