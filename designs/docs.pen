                          "content": "Concepts",
                          "fontFamily": "Space Grotesk",
                          "fontSize": 18,
                          "fontWeight": "600"
                        },
                        {
                          "type": "frame",
                          "id": "4Z3CI",
                          "name": "defList",
                          "width": "fill_container",
                          "layout": "vertical",
                          "gap": 10,
                          "padding": [
                            0,
                            0,
                            0,
                            8
                          ],
                          "children": [
                            {
                              "type": "frame",
                              "id": "nObDh",
                              "name": "df1",
                              "width": "fill_container",
                              "children": [
                                {
                                  "type": "text",
                                  "id": "95tCI",
                                  "name": "df1t",
                                  "fill": "#2D1F14",
                                  "textGrowth": "fixed-width",
                                  "width": "fill_container",
                                  "content": "Scaffold",
                                  "lineHeight": 1.6,
                                  "fontFamily": "Inter",
                                  "fontSize": 14,
                                  "fontWeight": "600"
                                },
                                {
                                  "type": "text",
                                  "id": "sd2Ee",
                                  "name": "df1d",
                                  "fill": "#785E48",
                                  "textGrowth": "fixed-width",
                                  "width": "fill_container",
                                  "content": " — The workspace initialization created by crucis init. By default generates only objective.yaml and src/solution.py (for new-project scaffolds). Use --with-profiles to also create constraints/profiles.yaml and --with-settings to also create .crucis/settings.yaml. Existing codebases are auto-detected or forced via --existing-codebase.",
                                  "lineHeight": 1.6,
                                  "fontFamily": "Inter",
                                  "fontSize": 14,
                                  "fontWeight": "normal"
                                }
                              ]
                            },
                            {
                              "type": "frame",
                              "id": "J0mFf",
                              "name": "dfPlan",
                              "width": "fill_container",
                              "children": [
                                {
                                  "type": "text",
                                  "id": "80B4n",
                                  "name": "dfPlanT",
                                  "fill": "#2D1F14",
                                  "textGrowth": "fixed-width",
                                  "width": "fill_container",
                                  "content": "Plan",
                                  "lineHeight": 1.6,
                                  "fontFamily": "Inter",
                                  "fontSize": 14,
                                  "fontWeight": "600"
                                },
                                {
                                  "type": "text",
                                  "id": "WsA8N",
                                  "name": "dfPlanD",
                                  "fill": "#785E48",
                                  "textGrowth": "fixed-width",
                                  "width": "fill_container",
                                  "content": " — A structured generation plan created by crucis run --plan. Written to plan.md in the workspace root. Guides the test generation agent with per-task file structure, test categories, and constraint compliance instructions.",
                                  "lineHeight": 1.6,
                                  "fontFamily": "Inter",
                                  "fontSize": 14,
                                  "fontWeight": "normal"
                                }
                              ]
                            },
                            {
                              "type": "frame",
                              "id": "DZeZn",
                              "name": "df2",
                              "width": "fill_container",
                              "children": [
                                {
                                  "type": "text",
                                  "id": "I59WY",
                                  "name": "df2t",
                                  "fill": "#2D1F14",
                                  "textGrowth": "fixed-width",
                                  "width": "fill_container",
                                  "content": "Objective",
                                  "lineHeight": 1.6,
                                  "fontFamily": "Inter",
                                  "fontSize": 14,
                                  "fontWeight": "600"
                                },
                                {
                                  "type": "text",
                                  "id": "ouJGS",
                                  "name": "df2d",
                                  "fill": "#785E48",
                                  "textGrowth": "fixed-width",
                                  "width": "fill_container",
                                  "content": " — A YAML file defining what Crucis should build. Contains a name, description, train evals, holdout evals, constraints, target files, and optional behaviors. Can be single-task or multi-task. See Objective Format Reference.",
                                  "lineHeight": 1.6,
                                  "fontFamily": "Inter",
                                  "fontSize": 14,
                                  "fontWeight": "normal"
                                }
                              ]
                            },
                            {
                              "type": "frame",
                              "id": "NW0Sg",
                              "name": "df3",
                              "width": "fill_container",
                              "children": [
                                {
                                  "type": "text",
                                  "id": "Z4VQ4",
                                  "name": "df3t",
                                  "fill": "#2D1F14",
                                  "textGrowth": "fixed-width",
                                  "width": "fill_container",
                                  "content": "Task",
                                  "lineHeight": 1.6,
                                  "fontFamily": "Inter",
                                  "fontSize": 14,
                                  "fontWeight": "600"
                                },
                                {
                                  "type": "text",
                                  "id": "mtUUm",
                                  "name": "df3d",
                                  "fill": "#785E48",
                                  "textGrowth": "fixed-width",
                                  "width": "fill_container",
                                  "content": " — One unit of work within an objective. Each task has its own name, signature, evals, constraint profile, and optional behaviors. Multi-task objectives list tasks under the tasks key.",
                                  "lineHeight": 1.6,
                                  "fontFamily": "Inter",
                                  "fontSize": 14,
                                  "fontWeight": "normal"
                                }
                              ]
                            },
                            {
                              "type": "frame",
                              "id": "nW6w5",
                              "name": "dfBehav",
                              "width": "fill_container",
                              "children": [
                                {
                                  "type": "text",
                                  "id": "mrfEK",
                                  "name": "dfBehavT",
                                  "fill": "#2D1F14",
                                  "textGrowth": "fixed-width",
                                  "width": "fill_container",
                                  "content": "Behaviors",
                                  "lineHeight": 1.6,
                                  "fontFamily": "Inter",
                                  "fontSize": 14,
                                  "fontWeight": "600"
                                },
                                {
                                  "type": "text",
                                  "id": "GCAZY",
                                  "name": "dfBehavD",
                                  "fill": "#785E48",
                                  "textGrowth": "fixed-width",
                                  "width": "fill_container",
                                  "content": " — An optional list[str] on objectives and tasks describing expected behavioral properties (e.g. &quot;idempotent&quot;, &quot;thread-safe&quot;, &quot;deterministic&quot;). Used to guide test generation and adversarial review.",
                                  "lineHeight": 1.6,
                                  "fontFamily": "Inter",
                                  "fontSize": 14,
                                  "fontWeight": "normal"
                                }
                              ]
                            },
                            {
                              "type": "frame",
                              "id": "v9DbN",
                              "name": "df4",
                              "width": "fill_container",
                              "children": [
                                {
                                  "type": "text",
                                  "id": "YhWhT",
                                  "name": "df4t",
                                  "fill": "#2D1F14",
                                  "textGrowth": "fixed-width",
                                  "width": "fill_container",
                                  "content": "Train Evals",
                                  "lineHeight": 1.6,
                                  "fontFamily": "Inter",
                                  "fontSize": 14,
                                  "fontWeight": "600"
                                },
                                {
                                  "type": "text",
                                  "id": "Peion",
                                  "name": "df4d",
                                  "fill": "#785E48",
                                  "textGrowth": "fixed-width",
                                  "width": "fill_container",
                                  "content": " — Visible input/output pairs used during test generation and adversarial review. Agents see these evals and use them to build pytest suites.",
                                  "lineHeight": 1.6,
                                  "fontFamily": "Inter",
                                  "fontSize": 14,
                                  "fontWeight": "normal"
                                }
                              ]
                            },
                            {
                              "type": "frame",
                              "id": "DUxva",
                              "name": "df5",
                              "width": "fill_container",
                              "children": [
                                {
                                  "type": "text",
                                  "id": "R51M6",
                                  "name": "df5t",
                                  "fill": "#2D1F14",
                                  "textGrowth": "fixed-width",
                                  "width": "fill_container",
                                  "content": "Holdout Evals",
                                  "lineHeight": 1.6,
                                  "fontFamily": "Inter",
                                  "fontSize": 14,
                                  "fontWeight": "600"
                                },
                                {
                                  "type": "text",
                                  "id": "r1hkI",
                                  "name": "df5d",
                                  "fill": "#785E48",
                                  "textGrowth": "fixed-width",
                                  "width": "fill_container",
                                  "content": " — Hidden input/output pairs never shown to any agent. Used only during final verification to ensure the implementation generalizes beyond known inputs. Failures are reported as counts only -- no payloads are leaked.",
                                  "lineHeight": 1.6,
                                  "fontFamily": "Inter",
                                  "fontSize": 14,
                                  "fontWeight": "normal"
                                }
                              ]
                            },
                            {
                              "type": "frame",
                              "id": "4tTnJ",
                              "name": "dfAutoH",
                              "width": "fill_container",
                              "children": [
                                {
                                  "type": "text",
                                  "id": "KzvSn",
                                  "name": "dfAutoHT",
                                  "fill": "#2D1F14",
                                  "textGrowth": "fixed-width",
                                  "width": "fill_container",
                                  "content": "Auto-Holdout",
                                  "lineHeight": 1.6,
                                  "fontFamily": "Inter",
                                  "fontSize": 14,
                                  "fontWeight": "600"
                                },
                                {
                                  "type": "text",
                                  "id": "c9pEW",
                                  "name": "dfAutoHD",
                                  "fill": "#785E48",
                                  "textGrowth": "fixed-width",
                                  "width": "fill_container",
                                  "content": " — When only examples (or train_evals) are provided without a holdout_evals key, Crucis automatically splits the last ~20% as holdout evals. To provide explicit holdout evals, add a holdout: key. To opt out of auto-holdout, set holdout: [].",
                                  "lineHeight": 1.6,
                                  "fontFamily": "Inter",
                                  "fontSize": 14,
                                  "fontWeight": "normal"
                                }
                              ]
                            },
                            {
                              "type": "frame",
                              "id": "NxTsn",
                              "name": "df6",
                              "width": "fill_container",
                              "children": [
                                {
                                  "type": "text",
                                  "id": "cLpB0",
                                  "name": "df6t",
                                  "fill": "#2D1F14",
                                  "textGrowth": "fixed-width",
                                  "width": "fill_container",
                                  "content": "Train Suite",
                                  "lineHeight": 1.6,
                                  "fontFamily": "Inter",
                                  "fontSize": 14,
                                  "fontWeight": "600"
                                },
                                {
                                  "type": "text",
                                  "id": "MKI0u",
                                  "name": "df6d",
                                  "fill": "#785E48",
                                  "textGrowth": "fixed-width",
                                  "width": "fill_container",
                                  "content": " — A generated pytest file containing tests for a task. Built by the generation agent from the objective, constraints, and train evals. Must pass syntax validation and constraint checks before approval.",
                                  "lineHeight": 1.6,
                                  "fontFamily": "Inter",
                                  "fontSize": 14,
                                  "fontWeight": "normal"
                                }
                              ]
                            },
                            {
                              "type": "frame",
                              "id": "kv5Q4",
                              "name": "df7",
                              "width": "fill_container",
                              "children": [
                                {
                                  "type": "text",
                                  "id": "9Epag",
                                  "name": "df7t",
                                  "fill": "#2D1F14",
                                  "textGrowth": "fixed-width",
                                  "width": "fill_container",
                                  "content": "Constraint Profile",
                                  "lineHeight": 1.6,
                                  "fontFamily": "Inter",
                                  "fontSize": 14,
                                  "fontWeight": "600"
                                },
                                {
                                  "type": "text",
                                  "id": "ZgUNK",
                                  "name": "df7d",
                                  "fill": "#785E48",
                                  "textGrowth": "fixed-width",
                                  "width": "fill_container",
                                  "content": " — A named set of constraints defined in constraints/profiles.yaml. Constraints are listed flat and auto-classified into required (blocking) or advisory based on the field type. The old nested primary:/secondary: format still works. Referenced by name in the objective YAML via tests_constraint_profile and implementation_constraint_profile. See Constraints Reference.",
                                  "lineHeight": 1.6,
                                  "fontFamily": "Inter",
                                  "fontSize": 14,
                                  "fontWeight": "normal"
                                }
                              ]
                            },
                            {
                              "type": "frame",
                              "id": "6gNvJ",
                              "name": "dfReqC",
                              "width": "fill_container",
                              "children": [
                                {
                                  "type": "text",
                                  "id": "NgEzY",
                                  "name": "dfReqCT",
                                  "fill": "#2D1F14",
                                  "textGrowth": "fixed-width",
                                  "width": "fill_container",
                                  "content": "Required Constraints",
                                  "lineHeight": 1.6,
                                  "fontFamily": "Inter",
                                  "fontSize": 14,
                                  "fontWeight": "600"
                                },
                                {
                                  "type": "text",
                                  "id": "6eG8A",
                                  "name": "dfReqCD",
                                  "fill": "#785E48",
                                  "textGrowth": "fixed-width",
                                  "width": "fill_container",
                                  "content": " — Hard gates -- if violated, the train suite is rejected and regenerated. Violations are fed back to the generation prompt. Most constraints are required by default.",
                                  "lineHeight": 1.6,
                                  "fontFamily": "Inter",
                                  "fontSize": 14,
                                  "fontWeight": "normal"
                                }
                              ]
                            },
                            {
                              "type": "frame",
                              "id": "iiE54",
                              "name": "dfAdvC",
                              "width": "fill_container",
                              "children": [
                                {
                                  "type": "text",
                                  "id": "3Grjw",
                                  "name": "dfAdvCT",
                                  "fill": "#2D1F14",
                                  "textGrowth": "fixed-width",
                                  "width": "fill_container",
                                  "content": "Advisory Constraints",
                                  "lineHeight": 1.6,
                                  "fontFamily": "Inter",
                                  "fontSize": 14,
                                  "fontWeight": "600"
                                },
                                {
                                  "type": "text",
                                  "id": "7cFY7",
                                  "name": "dfAdvCD",
                                  "fill": "#785E48",
                                  "textGrowth": "fixed-width",
                                  "width": "fill_container",
                                  "content": " — Soft gates -- violations are reported but don't block approval. Checked only after required constraints pass. Advisory fields: require_docstrings, no_print_statements, no_debugger_statements, no_global_state, require_type_annotations, no_nested_imports, no_star_imports, max_local_variables.",
                                  "lineHeight": 1.6,
                                  "fontFamily": "Inter",
                                  "fontSize": 14,
                                  "fontWeight": "normal"
                                }
                              ]
                            },
                            {
                              "type": "frame",
                              "id": "pxhp3",
                              "name": "df8",
                              "width": "fill_container",
                              "children": [
                                {
                                  "type": "text",
                                  "id": "BS0cD",
                                  "name": "df8t",
                                  "fill": "#2D1F14",
                                  "textGrowth": "fixed-width",
                                  "width": "fill_container",
                                  "content": "Adversarial Review",
                                  "lineHeight": 1.6,
                                  "fontFamily": "Inter",
                                  "fontSize": 14,
                                  "fontWeight": "600"
                                },
                                {
                                  "type": "text",
                                  "id": "3QTvG",
                                  "name": "df8d",
                                  "fill": "#785E48",
                                  "textGrowth": "fixed-width",
                                  "width": "fill_container",
                                  "content": " — The critic agent analyzes a train suite for weaknesses. Returns a JSON report with attack vectors, generalization gaps, and suggested probe tests.",
                                  "lineHeight": 1.6,
                                  "fontFamily": "Inter",
                                  "fontSize": 14,
                                  "fontWeight": "normal"
                                }
                              ]
                            },
                            {
                              "type": "frame",
                              "id": "DbvRx",
                              "name": "df9",
                              "width": "fill_container",
                              "children": [
                                {
                                  "type": "text",
                                  "id": "iSgkb",
                                  "name": "df9t",
                                  "fill": "#2D1F14",
                                  "textGrowth": "fixed-width",
                                  "width": "fill_container",
                                  "content": "Cheating Probe",
                                  "lineHeight": 1.6,
                                  "fontFamily": "Inter",
                                  "fontSize": 14,
                                  "fontWeight": "600"
                                },
                                {
                                  "type": "text",
                                  "id": "sOzw4",
                                  "name": "df9d",
                                  "fill": "#785E48",
                                  "textGrowth": "fixed-width",
                                  "width": "fill_container",
                                  "content": " — A deliberately cheating implementation generated to test whether the train suite can be passed by hardcoding, fingerprinting inputs, or using lookup tables. If the probe passes, the tests have gaps.",
                                  "lineHeight": 1.6,
                                  "fontFamily": "Inter",
                                  "fontSize": 14,
                                  "fontWeight": "normal"
                                }
                              ]
                            },
                            {
                              "type": "frame",
                              "id": "OcfxB",
                              "name": "df10",
                              "width": "fill_container",
                              "children": [
                                {
                                  "type": "text",
                                  "id": "unvL1",
                                  "name": "df10t",
                                  "fill": "#2D1F14",
                                  "textGrowth": "fixed-width",
                                  "width": "fill_container",
                                  "content": "Checkpoint",
                                  "lineHeight": 1.6,
                                  "fontFamily": "Inter",
                                  "fontSize": 14,
                                  "fontWeight": "600"
                                },
                                {
                                  "type": "text",
                                  "id": "931RE",
                                  "name": "df10d",
                                  "fill": "#785E48",
                                  "textGrowth": "fixed-width",
                                  "width": "fill_container",
                                  "content": " — A JSON file (.checkpoint.json) that persists progress across runs. Tracks each task's state, approved train suite source, adversarial report, and evaluation_passed status. Allows resuming interrupted runs. Use crucis run --reset to clear the entire checkpoint or --reset-task <name> to clear specific tasks.",
                                  "lineHeight": 1.6,
                                  "fontFamily": "Inter",
                                  "fontSize": 14,
                                  "fontWeight": "normal"
                                }
                              ]
                            },
                            {
                              "type": "frame",
                              "id": "epB5y",
                              "name": "df11",
                              "width": "fill_container",
                              "children": [
                                {
                                  "type": "text",
                                  "id": "4921e",
                                  "name": "df11t",
                                  "fill": "#2D1F14",
                                  "textGrowth": "fixed-width",
                                  "width": "fill_container",
                                  "content": "Curriculum",
                                  "lineHeight": 1.6,
                                  "fontFamily": "Inter",
                                  "fontSize": 14,
                                  "fontWeight": "600"
                                },
                                {
                                  "type": "text",
                                  "id": "hmqhC",
                                  "name": "df11d",
                                  "fill": "#785E48",
                                  "textGrowth": "fixed-width",
                                  "width": "fill_container",
                                  "content": " — A markdown file generated during evaluation containing the objective metadata, target files, test paths, and per-task details. This is the primary context sent to the implementation agent.",
                                  "lineHeight": 1.6,
                                  "fontFamily": "Inter",
                                  "fontSize": 14,
                                  "fontWeight": "normal"
                                }
                              ]
                            },
                            {
                              "type": "frame",
                              "id": "ZElcd",
                              "name": "df12",
                              "width": "fill_container",
                              "children": [
                                {
                                  "type": "text",
                                  "id": "SdE50",
                                  "name": "df12t",
                                  "fill": "#2D1F14",
                                  "textGrowth": "fixed-width",
                                  "width": "fill_container",
                                  "content": "Sandbox",
                                  "lineHeight": 1.6,
                                  "fontFamily": "Inter",
                                  "fontSize": 14,
                                  "fontWeight": "600"
                                },
                                {
                                  "type": "text",
                                  "id": "1VeUB",
                                  "name": "df12d",
                                  "fill": "#785E48",
                                  "textGrowth": "fixed-width",
                                  "width": "fill_container",
                                  "content": " — Docker-isolated pytest execution. Tests run inside a container to prevent generated code from affecting the host. Falls back to host pytest if Docker is unavailable.",
                                  "lineHeight": 1.6,
                                  "fontFamily": "Inter",
                                  "fontSize": 14,
                                  "fontWeight": "normal"
                                }
                              ]
                            },
                            {
                              "type": "frame",
                              "id": "T9q4o",
                              "name": "dfVerG",
                              "width": "fill_container",
                              "children": [
                                {
                                  "type": "text",
                                  "id": "zmRXd",
                                  "name": "dfVerGT",
                                  "fill": "#2D1F14",
                                  "textGrowth": "fixed-width",
                                  "width": "fill_container",
                                  "content": "Verification Granularity",
                                  "lineHeight": 1.6,
                                  "fontFamily": "Inter",
                                  "fontSize": 14,
                                  "fontWeight": "600"
                                },
                                {
                                  "type": "text",
                                  "id": "54tM6",
                                  "name": "dfVerGD",
                                  "fill": "#785E48",
                                  "textGrowth": "fixed-width",
                                  "width": "fill_container",
                                  "content": " — Controls how tests are verified: task (default) runs each task's tests independently; objective runs all tasks' tests together in a single pytest invocation.",
                                  "lineHeight": 1.6,
                                  "fontFamily": "Inter",
                                  "fontSize": 14,
                                  "fontWeight": "normal"
                                }
                              ]
                            },
                            {
                              "type": "frame",
                              "id": "ZtYvQ",
                              "name": "dfBgOpt",
                              "width": "fill_container",
                              "children": [
                                {
                                  "type": "text",
                                  "id": "XqWSl",
                                  "name": "dfBgOptT",
                                  "fill": "#2D1F14",
                                  "textGrowth": "fixed-width",
                                  "width": "fill_container",
                                  "content": "Background Optimizer",
                                  "lineHeight": 1.6,
                                  "fontFamily": "Inter",
                                  "fontSize": 14,
                                  "fontWeight": "600"
                                },
                                {
                                  "type": "text",
                                  "id": "ai5GH",
                                  "name": "dfBgOptD",
                                  "fill": "#785E48",
                                  "textGrowth": "fixed-width",
                                  "width": "fill_container",
                                  "content": " — An experimental GEPA-powered system that improves prompt steering over time. Disabled by default; enable with optimizer: enabled: true in .crucis/settings.yaml. After successful evaluation, a background worker scores candidate policies and promotes winners. See Background Optimizer.",
                                  "lineHeight": 1.6,
                                  "fontFamily": "Inter",
                                  "fontSize": 14,
                                  "fontWeight": "normal"
                                }
                              ]
                            },
                            {
                              "type": "frame",
                              "id": "NoE4O",
                              "name": "dfPolicy",
                              "width": "fill_container",
                              "children": [
                                {
                                  "type": "text",
                                  "id": "XyLX7",
                                  "name": "dfPolicyT",
                                  "fill": "#2D1F14",
                                  "textGrowth": "fixed-width",
                                  "width": "fill_container",
                                  "content": "Policy",
                                  "lineHeight": 1.6,
                                  "fontFamily": "Inter",
                                  "fontSize": 14,
                                  "fontWeight": "600"
                                },
                                {
                                  "type": "text",
                                  "id": "J8sdf",
                                  "name": "dfPolicyD",
                                  "fill": "#785E48",
                                  "textGrowth": "fixed-width",
                                  "width": "fill_container",
                                  "content": " — An optimizer policy that steers Crucis prompts. Contains four fields: repository_skill, generation_directives, adversary_directives, evaluation_directives. Each is injected into the corresponding prompt builder.",
                                  "lineHeight": 1.6,
                                  "fontFamily": "Inter",
                                  "fontSize": 14,
                                  "fontWeight": "normal"
                                }
                              ]
                            },
                            {
                              "type": "frame",
                              "id": "k5Vm7",
                              "name": "dfPromo",
                              "width": "fill_container",
                              "children": [
                                {
                                  "type": "text",
                                  "id": "y5PTW",
                                  "name": "dfPromoT",
                                  "fill": "#2D1F14",
                                  "textGrowth": "fixed-width",
